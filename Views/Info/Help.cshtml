@{
    ViewBag.Title = "Help";
}

<section style="padding:32px 4%;max-width:1000px;">
    <h1 style="color:#fff;margin-bottom:8px;">Help Center</h1>
    <p style="color:var(--text-muted)">Find guides, troubleshooting tips and ways to contact support.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:18px;">
        <div style="background:rgba(20,20,20,0.9);padding:14px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <h4 style="color:#fff;margin:0 0 8px">Account & Billing</h4>
            <p style="color:var(--text-muted);margin:0">Manage your subscription, payment methods and billing history.</p>
        </div>
        <div style="background:rgba(20,20,20,0.9);padding:14px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <h4 style="color:#fff;margin:0 0 8px">Playback & Devices</h4>
            <p style="color:var(--text-muted);margin:0">Troubleshoot playback issues and learn which devices we support.</p>
        </div>
        <div style="background:rgba(20,20,20,0.9);padding:14px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <h4 style="color:#fff;margin:0 0 8px">Profiles & Parental Controls</h4>
            <p style="color:var(--text-muted);margin:0">Set up kids profiles and enable content restrictions.</p>
        </div>
    </div>

    <p style="color:var(--text-muted);margin-top:18px">Still need help? Reach out to <a href="mailto:support@@watchit.example">support@@watchit.example</a>.</p>
</section>
