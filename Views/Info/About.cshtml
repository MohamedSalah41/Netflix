@{
    ViewBag.Title = "About";
}

<section class="about-page" style="padding:40px 4%;">
    <h1 style="font-size:32px;margin-bottom:8px;color:#fff;">About</h1>
    <p style="color:var(--text-muted);max-width:800px;">WatchIt is a small team of passionate developers and designers building an elegant streaming experience. Meet the team below.</p>

    <style>
        .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top:28px; }
        .team-card { background: rgba(20,20,20,0.9); border: 1px solid rgba(255,255,255,0.04); padding: 16px; border-radius: 12px; box-shadow: 0 6px 18px rgba(0,0,0,0.6); color: #fff; }
        .team-card img { width:100%; height:160px; object-fit:cover; border-radius:8px; display:block; }
        .team-card h3 { margin:10px 0 4px; font-size:18px; }
        .team-card p { margin:0;color:var(--text-muted);font-size:13px }
        .team-photos { display:flex; gap:10px; flex-wrap:wrap; margin-top:18px; }
        .team-photos img { width:120px; height:80px; object-fit:cover; border-radius:8px; border:1px solid rgba(255,255,255,0.04); }
        @@media (max-width:900px) { .team-grid { grid-template-columns: repeat(2, 1fr); } }
        @@media (max-width:600px) { .team-grid { grid-template-columns: 1fr; } @@media (max-width:480px){ .team-photos img{ width:100px;height:66px } } }
    </style>

    <div class="team-grid">
        <div class="team-card">
            <img src="/images/img1.svg" alt="Mohammed Abdallah" />
            <h3>Mohammed Abdallah</h3>
            <p>Frontend developer and UI designer. Focuses on building polished interfaces and animations.</p>
        </div>

        <div class="team-card">
            <img src="/images/img1.svg" alt="Saif" />
            <h3>Saif</h3>
            <p>Backend engineer, API design and performance optimizations.</p>
        </div>

        <div class="team-card">
            <img src="/images/img1.svg" alt="Mohammed Salah" />
            <h3>Mohammed Salah</h3>
            <p>Project lead — coordinates the team and ensures product quality.</p>
        </div>

        <div class="team-card">
            <img src="/images/img1.svg" alt="Mohammed Yaseer Sherbiny" />
            <h3>Mohammed Yaseer Sherbiny</h3>
            <p>Full-stack developer working across the stack to deliver features end-to-end.</p>
        </div>

        <div class="team-card">
            <img src="/images/img1.svg" alt="Mohammed Khalid" />
            <h3>Mohammed Khalid</h3>
            <p>DevOps and infrastructure — keeps deployments smooth and reliable.</p>
        </div>

        <div class="team-card">
            <img src="/images/img1.svg" alt="Moatasem" />
            <h3>Moatasem</h3>
            <p>Quality assurance and testing. Ensures the product works well across devices.</p>
        </div>
    </div>

    <div style="margin-top:36px;">
        <h2 style="font-size:20px;color:#fff;margin-bottom:10px;">Team snapshots</h2>
        <div class="team-photos">
            <img src="/images/img1.svg" alt="Team photo 1" />
            <img src="/images/img1.svg" alt="Team photo 2" />
            <img src="/images/img1.svg" alt="Team photo 3" />
            <img src="/images/img1.svg" alt="Team photo 4" />
        </div>
    </div>
</section>
