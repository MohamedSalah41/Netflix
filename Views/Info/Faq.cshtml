@{
    ViewBag.Title = "FAQ";
}

<section style="padding:32px 4%;max-width:900px;">
    <h1 style="color:#fff;margin-bottom:8px;">FAQ</h1>
    <p style="color:var(--text-muted)">Common questions and answers to help you get started.</p>

    <div style="margin-top:18px;display:flex;flex-direction:column;gap:12px;">
        <details style="background:rgba(20,20,20,0.9);padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <summary style="color:#fff;cursor:pointer;font-weight:600">How do I cancel my subscription?</summary>
            <div style="color:var(--text-muted);margin-top:8px">You can cancel from your account settings or visit the Plans page to manage your subscription.</div>
        </details>

        <details style="background:rgba(20,20,20,0.9);padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <summary style="color:#fff;cursor:pointer;font-weight:600">What devices are supported?</summary>
            <div style="color:var(--text-muted);margin-top:8px">WatchIt works on modern web browsers, Android and iOS devices, and many smart TVs. See the Devices page for details.</div>
        </details>

        <details style="background:rgba(20,20,20,0.9);padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.04)">
            <summary style="color:#fff;cursor:pointer;font-weight:600">How do I create profiles?</summary>
            <div style="color:var(--text-muted);margin-top:8px">Profiles can be created from the Manage Profiles section in your account. Each profile can have separate viewing preferences.</div>
        </details>
    </div>
</section>
