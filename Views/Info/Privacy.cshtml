@{
    ViewBag.Title = "Privacy";
}

<section style="padding:32px 4%;max-width:900px;">
    <h1 style="color:#fff;margin-bottom:8px;">Privacy Policy</h1>
    <p style="color:var(--text-muted)">This is a short, fictional privacy summary for demonstration purposes.</p>

    <h3 style="color:#fff;margin-top:18px">Information we collect</h3>
    <p style="color:var(--text-muted)">We collect account information (email, username), subscription and payment data, and usage information to provide and improve the service.</p>

    <h3 style="color:#fff;margin-top:12px">How we use data</h3>
    <p style="color:var(--text-muted)">Data is used to personalize recommendations, process payments, and ensure security.</p>

    <h3 style="color:#fff;margin-top:12px">Cookies</h3>
    <p style="color:var(--text-muted)">We use cookies for authentication, preferences and analytics. See our Cookies page for details.</p>

    <h3 style="color:#fff;margin-top:12px">Contact</h3>
    <p style="color:var(--text-muted)">Questions about privacy? Email <a href="mailto:privacy@@watchit.example">privacy@@watchit.example</a>.</p>
</section>
