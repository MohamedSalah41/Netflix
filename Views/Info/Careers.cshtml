@{
    ViewBag.Title = "Careers";
}

<section style="padding:32px 4%;">
    <h1 style="color:#fff;margin-bottom:8px;">Careers</h1>
    <p style="color:var(--text-muted);max-width:900px;">We're growing — join our team. Below are some fictional openings to illustrate how careers listings will appear.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;margin-top:20px;">
        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin-top:0;color:#fff">Frontend Engineer</h3>
            <p style="color:var(--text-muted)">Work on our React-based UI, build responsive components and craft delightful interactions.</p>
            <p style="color:var(--text-muted);font-size:13px"><strong>Location:</strong> Remote · <strong>Type:</strong> Full-time</p>
            <a href="mailto:jobs@@watchit.example?subject=Frontend%20Engineer%20Application" style="display:inline-block;margin-top:10px;padding:8px 12px;border-radius:8px;background:var(--brand);color:#fff">Apply</a>
        </article>

        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin-top:0;color:#fff">Backend Engineer</h3>
            <p style="color:var(--text-muted)">Design scalable APIs, work with databases and improve performance across the platform.</p>
            <p style="color:var(--text-muted);font-size:13px"><strong>Location:</strong> Cairo · <strong>Type:</strong> Full-time</p>
            <a href="mailto:jobs@@watchit.example?subject=Backend%20Engineer%20Application" style="display:inline-block;margin-top:10px;padding:8px 12px;border-radius:8px;background:var(--brand);color:#fff">Apply</a>
        </article>

        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin-top:0;color:#fff">DevOps / Site Reliability</h3>
            <p style="color:var(--text-muted)">Manage deployments, CI/CD pipelines and cloud infrastructure to keep WatchIt available and fast.</p>
            <p style="color:var(--text-muted);font-size:13px"><strong>Location:</strong> Remote · <strong>Type:</strong> Contract</p>
            <a href="mailto:jobs@@watchit.example?subject=DevOps%20Application" style="display:inline-block;margin-top:10px;padding:8px 12px;border-radius:8px;background:var(--brand);color:#fff">Apply</a>
        </article>
    </div>

    <p style="color:var(--text-muted);margin-top:20px;">Don’t see a role that fits? Send a general application to <a href="mailto:talent@@watchit.example">talent@@watchit.example</a>.</p>
</section>
