@{
    ViewBag.Title = "Press";
}

<section style="padding:32px 4%;">
    <h1 style="color:#fff;margin-bottom:8px;">Press</h1>
    <p style="color:var(--text-muted);max-width:900px;">Recent announcements and press releases from WatchIt (mock data).</p>

    <div style="margin-top:20px;display:flex;flex-direction:column;gap:14px;">
        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin:0 0 6px;color:#fff">WatchIt launches new family profiles</h3>
            <div style="color:var(--text-muted);font-size:13px;margin-bottom:8px">May 10, 2026</div>
            <p style="color:var(--text-muted);margin:0">WatchIt introduced family profiles to make it easier for households to manage viewing preferences and parental controls.</p>
        </article>

        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin:0 0 6px;color:#fff">Partnership with StudioX for exclusive content</h3>
            <div style="color:var(--text-muted);font-size:13px;margin-bottom:8px">Apr 6, 2026</div>
            <p style="color:var(--text-muted);margin:0">WatchIt signed a deal with StudioX to stream three original series beginning later this year.</p>
        </article>

        <article style="background:rgba(20,20,20,0.9);padding:16px;border-radius:10px;border:1px solid rgba(255,255,255,0.04)">
            <h3 style="margin:0 0 6px;color:#fff">Improved streaming quality with new CDN</h3>
            <div style="color:var(--text-muted);font-size:13px;margin-bottom:8px">Mar 1, 2026</div>
            <p style="color:var(--text-muted);margin:0">We rolled out a new CDN provider to improve playback performance across regions.</p>
        </article>
    </div>
</section>
