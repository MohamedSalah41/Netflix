@model Netflix_clone.Models.Series

@{
    ViewData["Title"] = "Add Series";
    ViewBag.ActivePage = "Series";
}

<partial name="_MovieFormStyle" />

<div class="form-page">

    <div class="form-card">

        <div class="form-card__header">

            <div class="form-card__icon">📺</div>

            <div>
                <div class="form-card__title">Add Series</div>
                <div class="form-card__sub">
                    Add a new series to the platform.
                </div>
            </div>

        </div>

        <form asp-action="AddSeries">

            <div class="form-card__body">

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" />
                </div>

                <div class="form-field">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-input"></textarea>
                </div>

                <div class="form-field">
                    <label asp-for="Poster" class="form-label"></label>
                    <input asp-for="Poster" class="form-input" />
                </div>

                <div class="form-field">
                    <label asp-for="TrailerUrl" class="form-label"></label>
                    <input asp-for="TrailerUrl" class="form-input" />
                </div>

                <div class="form-field">
                    <label asp-for="Rating" class="form-label"></label>
                    <input asp-for="Rating" class="form-input" />
                </div>
                <div class="form-field">

                    <label class="form-label">
                        Actors
                    </label>

                    <select name="actorIds"
                            class="form-input"
                            multiple
                            style="height:220px;">

                        @foreach (var actor in ViewBag.Actors)
                        {
                            <option value="@actor.Id">
                                @actor.Name
                            </option>
                        }

                    </select>

                </div>
                <div class="form-field">

                    <label class="form-label">
                        Categories
                    </label>

                    <select name="categoryIds"
                            class="form-input"
                            multiple
                            style="height:220px;">

                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.Id">
                                @category.Name
                            </option>
                        }

                    </select>

                </div>

            </div>

            <div class="form-footer">

                <a asp-action="GetAllSeries" class="btn-ghost">
                    Cancel
                </a>

                <button type="submit" class="btn-submit">
                    Save Series
                </button>

            </div>

        </form>

    </div>

</div>