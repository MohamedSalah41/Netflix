@model Netflix_clone.Models.Series

@{
    ViewData["Title"] = Model.Name;
}

<style>

    .details-page {
        padding: 40px;
    }

    .series-hero {
        position: relative;
        min-height: 550px;
        border-radius: 28px;
        overflow: hidden;
        display: flex;
        align-items: end;
        padding: 50px;
        background-size: cover;
        background-position: center;
        margin-bottom: 40px;
    }

    .series-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0,0,0,.96), rgba(0,0,0,.55), rgba(0,0,0,.25) );
    }

    .series-content {
        position: relative;
        z-index: 2;
        max-width: 750px;
    }

    .series-title {
        font-size: 72px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .series-meta {
        display: flex;
        gap: 18px;
        margin-bottom: 20px;
        color: #d1d5db;
        font-size: 14px;
    }

    .series-description {
        color: #e5e7eb;
        line-height: 1.9;
        font-size: 16px;
        margin-bottom: 30px;
    }

    .section-title {
        font-size: 28px;
        margin-bottom: 24px;
        margin-top: 40px;
    }

    .seasons-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(240px,1fr));
        gap: 20px;
    }

    .season-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-medium);
        border-radius: 20px;
        padding: 24px;
        transition: .2s;
    }

        .season-card:hover {
            transform: translateY(-4px);
        }

    .season-number {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .season-text {
        color: var(--text-muted);
        font-size: 14px;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 12px;
    }

    .tag {
        padding: 10px 16px;
        border-radius: 999px;
        background: var(--bg-surface);
        border: 1px solid var(--border-medium);
        font-size: 13px;
    }

    .series-trailer {
        width: 100%;
        margin-top: 40px;
        display: flex;
        justify-content: center;
    }

        .series-trailer iframe {
            width: 90%;
            height: 800px;
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,.45);
        }

    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(160px,1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .cast-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-medium);
        border-radius: 22px;
        overflow: hidden;
        transition: .2s;
        cursor: pointer;
    }

        .cast-card:hover {
            transform: translateY(-6px);
        }

    .cast-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .cast-name {
        padding: 16px;
        font-size: 14px;
        font-weight: 600;
        text-align: center;
    }

</style>

<div class="details-page">

    <!-- HERO -->

    <div class="series-hero"
         style="background-image:url('@Model.Poster')">

        <div class="series-overlay"></div>

        <div class="series-content">

            <div class="series-title">
                @Model.Name
            </div>

            <div class="series-meta">

                <span>
                    ⭐ @Model.Rating
                </span>

                <span>
                    📺 @Math.Max(Model.Seasons.Count,1) Season(s)
                </span>

            </div>
            

            <div class="series-description">
                @Model.Description
            </div>

            <a asp-action="UpdateSeries"
               asp-route-id="@Model.Id"
               class="btn-submit">
                Edit Series
            </a>

        </div>

    </div>
    <div class="series-trailer">

        <iframe src="@Model.TrailerUrl"
                title="Series Trailer"
                allowfullscreen>
        </iframe>

    </div>

    <!-- SEASONS -->

    <div>

        <div class="section-title">
            Seasons
        </div>

        <div class="seasons-grid">

            @foreach (var season in Model.Seasons)
            {
                <div class="season-card">

                    <div class="season-number">
                        Season @season.Number
                    </div>

                    <div class="season-text">
                        Episodes:
                        @(season.Episodes?.Count ?? 0)
                    </div>

                </div>
            }

        </div>

    </div>

    <!-- ACTORS -->

    <div>

        <div class="section-title">
            Cast
        </div>

        <div class="cast-grid">

            @foreach (var actor in Model.Actors)
            {
                <a asp-controller="Actor"
                   asp-action="GetActorByID"
                   asp-route-id="@actor.Id"
                   class="cast-card-link">

                    <div class="cast-card">

                        <img src="@actor.Photo"
                             class="cast-image" />

                        <div class="cast-name">
                            @actor.Name
                        </div>

                    </div>

                </a>
            }

        </div>

    </div>

    <!-- CATEGORIES -->

    <div>

        <div class="section-title">
            Categories
        </div>

        <div class="tags">

            @foreach (var category in Model.Categories)
            {
                <div class="tag">
                    🎬 @category.Name
                </div>
            }

        </div>

    </div>

</div>