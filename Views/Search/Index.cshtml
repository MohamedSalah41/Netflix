@model Netflix_clone.Models.SearchResultsViewModel

@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.Query) ? "Search" : $"Search results for '{Model.Query}'";
}

<style>
    .search-page {
        padding: 40px 24px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .search-header {
        margin-bottom: 40px;
    }

    .search-title {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .search-subtitle {
        font-size: 16px;
        color: var(--text-secondary);
    }

    .search-form {
        margin-bottom: 40px;
        display: flex;
        gap: 12px;
        max-width: 600px;
    }

    .search-form input {
        flex: 1;
        padding: 14px 20px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-medium);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 16px;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-form input:focus {
        border-color: var(--brand);
    }

    .search-form button {
        padding: 14px 32px;
        background: var(--brand);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .search-form button:hover {
        background: var(--brand-hover);
    }

    .search-section {
        margin-bottom: 48px;
    }

    .section-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .section-count {
        font-size: 16px;
        color: var(--text-secondary);
        font-weight: 400;
    }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }

    .result-card {
        background: var(--bg-surface);
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

    .result-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .result-poster {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        background: var(--bg-elevated);
    }

    .result-info {
        padding: 12px;
    }

    .result-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .result-type {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .no-results {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary);
    }

    .no-results-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .no-results-text {
        font-size: 18px;
        margin-bottom: 8px;
    }

    .list-results {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .list-item {
        background: var(--bg-surface);
        padding: 16px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: background 0.2s;
    }

    .list-item:hover {
        background: var(--bg-elevated);
    }

    .list-item-icon {
        font-size: 24px;
    }

    .list-item-name {
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
    }
</style>

<div class="search-page">
    <div class="search-header">
        <h1 class="search-title">
            @if (string.IsNullOrEmpty(Model.Query))
            {
                <text>Search</text>
            }
            else
            {
                <text>Search Results</text>
            }
        </h1>
        @if (!string.IsNullOrEmpty(Model.Query))
        {
            <p class="search-subtitle">
                Showing results for "<strong>@Model.Query</strong>"
            </p>
        }
    </div>

    <form class="search-form" method="get" asp-action="Index">
        <input type="search" 
               name="query" 
               placeholder="Search for movies, series, actors, categories..." 
               value="@Model.Query"
               autofocus />
        <button type="submit">Search</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Query))
    {
        var totalResults = (Model.Movies?.Count ?? 0) + 
                          (Model.Series?.Count ?? 0) + 
                          (Model.Episodes?.Count ?? 0) + 
                          (Model.Categories?.Count ?? 0) + 
                          (Model.Actors?.Count ?? 0);

        if (totalResults == 0)
        {
            <div class="no-results">
                <div class="no-results-icon">🔍</div>
                <div class="no-results-text">No results found</div>
                <p>Try searching with different keywords</p>
            </div>
        }
        else
        {
            @if (Model.Movies?.Any() == true)
            {
                <div class="search-section">
                    <h2 class="section-title">
                        Movies
                        <span class="section-count">(@Model.Movies.Count)</span>
                    </h2>
                    <div class="results-grid">
                        @foreach (var movie in Model.Movies)
                        {
                            <a href="@Url.Action("Details", "Movie", new { id = movie.Id })" class="result-card">
                                <img src="@movie.Poster" alt="@movie.Name" class="result-poster" />
                                <div class="result-info">
                                    <div class="result-name">@movie.Name</div>
                                    <div class="result-type">Movie</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.Series?.Any() == true)
            {
                <div class="search-section">
                    <h2 class="section-title">
                        Series
                        <span class="section-count">(@Model.Series.Count)</span>
                    </h2>
                    <div class="results-grid">
                        @foreach (var series in Model.Series)
                        {
                            <a href="@Url.Action("GetSeriesById", "Series", new { id = series.Id })" class="result-card">
                                <img src="@series.Poster" alt="@series.Name" class="result-poster" />
                                <div class="result-info">
                                    <div class="result-name">@series.Name</div>
                                    <div class="result-type">Series</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.Episodes?.Any() == true)
            {
                <div class="search-section">
                    <h2 class="section-title">
                        Episodes
                        <span class="section-count">(@Model.Episodes.Count)</span>
                    </h2>
                    <div class="results-grid">
                        @foreach (var episode in Model.Episodes)
                        {
                            <a href="@Url.Action("Details", "Episode", new { id = episode.Id })" class="result-card">
                                <img src="@episode.Poster" alt="@episode.Name" class="result-poster" />
                                <div class="result-info">
                                    <div class="result-name">@episode.Name</div>
                                    <div class="result-type">Episode</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.Categories?.Any() == true)
            {
                <div class="search-section">
                    <h2 class="section-title">
                        Categories
                        <span class="section-count">(@Model.Categories.Count)</span>
                    </h2>
                    <div class="list-results">
                        @foreach (var category in Model.Categories)
                        {
                            <div class="list-item">
                                <div class="list-item-icon">🎭</div>
                                <div class="list-item-name">@category.Name</div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.Actors?.Any() == true)
            {
                <div class="search-section">
                    <h2 class="section-title">
                        Actors
                        <span class="section-count">(@Model.Actors.Count)</span>
                    </h2>
                    <div class="list-results">
                        @foreach (var actor in Model.Actors)
                        {
                            <a href="@Url.Action("GetActorByID", "Actor", new { id = actor.Id })" class="list-item">
                                <div class="list-item-icon">⭐</div>
                                <div class="list-item-name">@actor.Name</div>
                            </a>
                        }
                    </div>
                </div>
            }
        }
    }
</div>
