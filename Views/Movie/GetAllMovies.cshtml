@model IEnumerable<Netflix_clone.Models.Movie>

@{
    ViewData["Title"] = "Movies";
    ViewBag.ActivePage = "Movies";
}

<style>

    .movies-page {
        padding: 40px;
    }

    .movies-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .movies-title h1 {
        font-size: 34px;
        margin-bottom: 6px;
    }

    .movies-title p {
        color: var(--text-muted);
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
        gap: 24px;
    }

    .movie-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-medium);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .movie-poster {
        width: 100%;
        height: 360px;
        object-fit: cover;
    }

    .movie-content {
        padding: 20px;
    }

    .movie-name {
        font-size: 22px;
        margin-bottom: 10px;
    }

    .movie-description {
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 18px;
    }

    .movie-actions {
        display: flex;
        gap: 12px;
    }

    .movie-btn {
        flex: 1;
        text-align: center;
        padding: 10px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
    }

    .edit-btn {
        background: var(--brand);
        color: white;
    }

    .delete-btn {
        border: 1px solid #ef4444;
        color: #ef4444;
    }

    .movie-card {
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .movie-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.3);
        }

</style>

<div class="movies-page">

    <div class="movies-header">

        <div class="movies-title">
            <h1>Movies</h1>
            <p>Manage all movies in the system.</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
        <a asp-action="AddMovie" class="btn-submit">
            + Add Movie
        </a>
        }

    </div>

    <div class="movies-grid">

        @foreach (var item in Model)
        {
            <div class="movie-card"
                 onclick="window.location='@Url.Action("Details", "Movie", new { id = item.Id })'">

                <img src="@item.Poster" class="movie-poster" />

                <div class="movie-content">

                    <div class="movie-name">
                        @item.Name
                    </div>

                    <div class="movie-description">
                        @item.Description
                    </div>

                    <div class="movie-actions">

                        @if (User.IsInRole("Admin"))
                        {
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="movie-btn edit-btn"
                           onclick="event.stopPropagation();">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="movie-btn delete-btn"
                           onclick="event.stopPropagation();">
                            Delete
                        </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>