@model Netflix_clone.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
    ViewBag.ActivePage = "Movies";

    string formTitle = "Delete Movie";
    string formSubtitle = "This action cannot be undone.";
    string formIcon = "🗑️";
    string backAction = "GetAllMovies";
    string backLabel = "Back to Movies";
}

<partial name="_MovieFormStyle" />

<div class="form-page">

    <a asp-action="@backAction" class="form-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6" />
        </svg>
        @backLabel
    </a>

    <div class="form-card">

        <div class="form-card__header">
            <div class="form-card__icon">@formIcon</div>

            <div>
                <div class="form-card__title">@formTitle</div>
                <div class="form-card__sub">@formSubtitle</div>
            </div>
        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <div class="form-card__body">

                <div class="form-field">
                    <label class="form-label">Movie Name</label>
                    <input value="@Model.Name" class="form-input" readonly />
                </div>

                <div class="form-field">
                    <label class="form-label">Description</label>
                    <textarea class="form-textarea" readonly>@Model.Description</textarea>
                </div>

                <div class="form-field">
                    <label class="form-label">Poster</label>
                    <input value="@Model.Poster" class="form-input" readonly />
                </div>

            </div>

            <div class="form-footer">

                <a asp-action="@backAction" class="btn-ghost">
                    Cancel
                </a>

                <button type="submit" class="btn-submit">
                    Delete Movie
                </button>

            </div>

        </form>

    </div>

</div>