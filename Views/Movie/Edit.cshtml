@model Netflix_clone.Models.Movie
@{
    ViewData["Title"] = "Edit Movie";
    ViewBag.ActivePage = "Movies";

    var selectedActorIds    = (ViewBag.SelectedActorIds    as List<int>) ?? new List<int>();
    var selectedCategoryIds = (ViewBag.SelectedCategoryIds as List<int>) ?? new List<int>();
}

<style>
    .form-page {
        max-width : 780px;
        margin    : 40px auto;
        padding   : 0 24px 64px;
    }
    .form-back {
        display        : inline-flex;
        align-items    : center;
        gap            : 6px;
        font-size      : 13px;
        color          : var(--text-muted);
        text-decoration: none;
        margin-bottom  : 28px;
        transition     : color 180ms;
    }
    .form-back:hover { color: var(--text-secondary); }
    .form-card {
        background   : var(--bg-surface);
        border       : 1px solid var(--border-medium);
        border-radius: var(--radius-lg);
        overflow     : hidden;
    }
    .form-card__header {
        padding      : 28px 32px 24px;
        border-bottom: 1px solid var(--border-subtle);
        display      : flex;
        align-items  : center;
        gap          : 16px;
    }
    .form-card__icon {
        width           : 48px;
        height          : 48px;
        border-radius   : 12px;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.25);
        display         : flex;
        align-items     : center;
        justify-content : center;
        font-size       : 22px;
        flex-shrink     : 0;
    }
    .form-card__title {
        font-family   : var(--font-display);
        font-size     : 26px;
        letter-spacing: 1px;
        color         : var(--text-primary);
        line-height   : 1;
    }
    .form-card__sub { font-size: 13px; color: var(--text-muted); margin-top: 5px; }
    .form-card__body { padding: 32px; }
    .form-error-box {
        background   : rgba(248,113,113,0.08);
        border       : 1px solid rgba(248,113,113,0.3);
        border-radius: var(--radius-md);
        padding      : 12px 16px;
        margin-bottom: 24px;
        font-size    : 13px;
        color        : #fca5a5;
    }
    .form-field { margin-bottom: 24px; }
    .form-label {
        display       : block;
        font-size     : 12px;
        font-weight   : 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color         : var(--text-secondary);
        margin-bottom : 8px;
    }
    .form-input {
        width        : 100%;
        padding      : 11px 16px;
        background   : var(--bg-elevated);
        border       : 1px solid var(--border-medium);
        border-radius: var(--radius-md);
        color        : var(--text-primary);
        font-family  : var(--font-body);
        font-size    : 14px;
        outline      : none;
        transition   : border-color 200ms, box-shadow 200ms;
    }
    .form-input::placeholder { color: var(--text-muted); }
    .form-input:focus {
        border-color: var(--brand);
        box-shadow  : 0 0 0 3px var(--brand-dim);
    }
    .form-field-error { display: block; font-size: 12px; color: #f87171; margin-top: 6px; }

    .picker-search {
        width        : 100%;
        padding      : 9px 14px;
        background   : var(--bg-elevated);
        border       : 1px solid var(--border-medium);
        border-radius: var(--radius-md);
        color        : var(--text-primary);
        font-family  : var(--font-body);
        font-size    : 13px;
        outline      : none;
        margin-bottom: 10px;
        transition   : border-color 200ms;
    }
    .picker-search:focus { border-color: var(--brand); }
    .picker-search::placeholder { color: var(--text-muted); }

    .chip-grid {
        display  : flex;
        flex-wrap: wrap;
        gap      : 8px;
        max-height: 220px;
        overflow-y: auto;
        padding  : 4px 2px;
        scrollbar-width: thin;
        scrollbar-color: var(--border-medium) transparent;
    }
    .chip {
        display      : inline-flex;
        align-items  : center;
        gap          : 6px;
        padding      : 6px 14px;
        border-radius: var(--radius-full);
        font-size    : 13px;
        font-weight  : 500;
        cursor       : pointer;
        user-select  : none;
        border       : 1px solid var(--border-medium);
        background   : var(--bg-elevated);
        color        : var(--text-secondary);
        transition   : background 150ms, border-color 150ms, color 150ms;
    }
    .chip:hover { background: var(--bg-surface); color: var(--text-primary); }
    .chip.selected {
        background  : var(--brand-dim);
        border-color: rgba(229,9,20,0.45);
        color       : var(--brand);
    }
    .chip.selected .chip-check { display: inline; }
    .chip-check { display: none; }
    .chip.hidden { display: none; }

    .chip-link {
        display        : inline-flex;
        align-items    : center;
        margin-left    : 4px;
        color          : inherit;
        opacity        : 0.5;
        text-decoration: none;
        transition     : opacity 150ms;
        flex-shrink    : 0;
    }
    .chip-link:hover { opacity: 1; }
    .chip.selected .chip-link { color: var(--brand); }

    .selected-summary {
        margin-top : 10px;
        font-size  : 12px;
        color      : var(--text-muted);
        min-height : 18px;
    }
    .selected-summary span {
        color      : var(--brand);
        font-weight: 600;
    }

    .form-footer {
        padding        : 24px 32px;
        border-top     : 1px solid var(--border-subtle);
        display        : flex;
        align-items    : center;
        justify-content: flex-end;
        gap            : 12px;
    }
    .btn-ghost {
        display        : inline-flex;
        align-items    : center;
        gap            : 6px;
        padding        : 10px 20px;
        border-radius  : var(--radius-full);
        font-family    : var(--font-body);
        font-size      : 13px;
        font-weight    : 500;
        color          : var(--text-secondary);
        background     : transparent;
        border         : 1px solid var(--border-medium);
        text-decoration: none;
        transition     : color 180ms, background 180ms;
    }
    .btn-ghost:hover { color: var(--text-primary); background: var(--bg-elevated); }
    .btn-submit {
        display      : inline-flex;
        align-items  : center;
        gap          : 8px;
        padding      : 10px 24px;
        background   : var(--brand);
        color        : #fff;
        font-family  : var(--font-body);
        font-size    : 13px;
        font-weight  : 600;
        border-radius: var(--radius-full);
        border       : none;
        cursor       : pointer;
        transition   : background 200ms, box-shadow 200ms, transform 150ms;
    }
    .btn-submit:hover {
        background: var(--brand-hover);
        box-shadow: var(--shadow-brand);
        transform : translateY(-1px);
    }

    @@media (max-width: 600px) {
        .form-page { padding: 0 12px 48px; margin-top: 24px; }
        .form-card__header, .form-card__body, .form-footer { padding: 20px; }
        .form-footer { flex-direction: column-reverse; }
        .btn-ghost, .btn-submit { width: 100%; justify-content: center; }
    }
</style>

<div class="form-page">
    <a asp-action="GetAllMovies" class="form-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back to Movies
    </a>

    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon" aria-hidden="true">✏️</div>
            <div>
                <div class="form-card__title">Edit Movie</div>
                <div class="form-card__sub">Update movie details, cast and categories.</div>
            </div>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" id="editForm" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="form-error-box text-danger"></div>

            <div class="form-card__body">

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" />
                    <span asp-validation-for="Name" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-input" rows="3"></textarea>
                    <span asp-validation-for="Description" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Poster" class="form-label"></label>
                    <input asp-for="Poster" class="form-input" placeholder="https://example.com/poster.jpg" />
                    <span asp-validation-for="Poster" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="VideoUrl" class="form-label"></label>
                    <input asp-for="VideoUrl" class="form-input" placeholder="https://youtube.com/watch?v=..." />
                    <span asp-validation-for="VideoUrl" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="TrailerUrl" class="form-label"></label>
                    <input asp-for="TrailerUrl" class="form-input" placeholder="https://youtu.be/pvKkBUM3Dyc" />
                    <span asp-validation-for="TrailerUrl" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="DurationSeconds" class="form-label"></label>
                    <input asp-for="DurationSeconds" class="form-input" type="time" step="1" />
                    <span asp-validation-for="DurationSeconds" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Rating" class="form-label"></label>
                    <input asp-for="Rating" class="form-input" type="number" step="0.1" min="0" max="10" />
                    <span asp-validation-for="Rating" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label class="form-label">Actors</label>
                    <input type="text" class="picker-search" id="actorSearch" placeholder="Search actors…" autocomplete="off" />
                    <div class="chip-grid" id="actorChips">
                        @foreach (var actor in (ViewBag.Actors as IEnumerable<Netflix_clone.Models.Actor> ?? Enumerable.Empty<Netflix_clone.Models.Actor>()))
                        {
                            bool sel = selectedActorIds.Contains(actor.Id);
                            <div class="chip @(sel ? "selected" : "")" data-name="@actor.Name.ToLower()">
                                <input type="checkbox" name="actorIds" value="@actor.Id"
                                       @(sel ? "checked" : "") style="display:none" />
                                <svg class="chip-check" width="12" height="12" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                <span class="chip-toggle">@actor.Name</span>
                                <a href="@Url.Action("GetActorByID", "Actor", new { id = actor.Id })"
                                   class="chip-link" title="View actor" target="_blank">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2.5">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                        <polyline points="15 3 21 3 21 9"/>
                                        <line x1="10" y1="14" x2="21" y2="3"/>
                                    </svg>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="selected-summary" id="actorSummary"></div>
                </div>

                <div class="form-field">
                    <label class="form-label">Categories</label>
                    <input type="text" class="picker-search" id="categorySearch" placeholder="Search categories…" autocomplete="off" />
                    <div class="chip-grid" id="categoryChips">
                        @foreach (var cat in (ViewBag.Categories as IEnumerable<Netflix_clone.Models.Category> ?? Enumerable.Empty<Netflix_clone.Models.Category>()))
                        {
                            bool sel = selectedCategoryIds.Contains(cat.Id);
                            <div class="chip @(sel ? "selected" : "")" data-name="@cat.Name.ToLower()">
                                <input type="checkbox" name="categoryIds" value="@cat.Id"
                                       @(sel ? "checked" : "") style="display:none" />
                                <svg class="chip-check" width="12" height="12" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                <span class="chip-toggle">@cat.Name</span>
                                <a href="@Url.Action("Index", "Category")"
                                   class="chip-link" title="View category" target="_blank">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2.5">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                        <polyline points="15 3 21 3 21 9"/>
                                        <line x1="10" y1="14" x2="21" y2="3"/>
                                    </svg>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="selected-summary" id="categorySummary"></div>
                </div>

            </div>

            <div class="form-footer">
                <a asp-action="GetAllMovies" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
    (function () {
        function initPicker(gridId, searchId, summaryId, label) {
            const grid   = document.getElementById(gridId);
            const search = document.getElementById(searchId);
            const summary = document.getElementById(summaryId);
            if (!grid || !search) return;

            const chips = Array.from(grid.querySelectorAll('.chip'));

            function updateSummary() {
                const sel = chips.filter(c => c.classList.contains('selected'));
                summary.innerHTML = sel.length
                    ? '<span>' + sel.length + '</span> ' + label + (sel.length !== 1 ? 's' : '') + ' selected'
                    : 'None selected';
            }

            chips.forEach(chip => {
                const cb = chip.querySelector('input[type="checkbox"]');
                chip.addEventListener('click', function (e) {
                    if (e.target.closest('.chip-link')) return;
                    chip.classList.toggle('selected');
                    cb.checked = chip.classList.contains('selected');
                    updateSummary();
                });
            });

            search.addEventListener('input', function () {
                const q = search.value.trim().toLowerCase();
                chips.forEach(chip => {
                    chip.classList.toggle('hidden', q !== '' && !chip.dataset.name.includes(q));
                });
            });

            updateSummary();
        }

        initPicker('actorChips',    'actorSearch',    'actorSummary',    'actor');
        initPicker('categoryChips', 'categorySearch', 'categorySummary', 'category');
    })();
    </script>
}
