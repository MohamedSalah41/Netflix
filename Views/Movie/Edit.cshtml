@model Netflix_clone.Models.Movie

@{
    ViewData["Title"] = "Edit Movie";
    ViewBag.ActivePage = "Movies";

    string formTitle = "Edit Movie";
    string formSubtitle = "Update movie information.";
    string formIcon = "✏️";
    string backAction = "GetAllMovies";
    string backLabel = "Back to Movies";
}

<partial name="_MovieFormStyle" />

<div class="form-page">

    <a asp-action="@backAction" class="form-back">
        ← @backLabel
    </a>

    <div class="form-card">

        <div class="form-card__header">
            <div class="form-card__icon">@formIcon</div>

            <div>
                <div class="form-card__title">@formTitle</div>
                <div class="form-card__sub">@formSubtitle</div>
            </div>
        </div>

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="form-error-box"></div>

            <div class="form-card__body">

                <div class="form-field">
                    <label asp-for="VideoUrl" class="form-label"></label>
                    <input asp-for="VideoUrl" class="form-input" />
                    <span asp-validation-for="VideoUrl" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="DurationSeconds" class="form-label"></label>
                    <input asp-for="DurationSeconds" type="time" step="1" class="form-input" />
                    <span asp-validation-for="DurationSeconds" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" />
                    <span asp-validation-for="Name" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-input" />
                    <span asp-validation-for="Description" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Poster" class="form-label"></label>
                    <input asp-for="Poster"
                           class="form-input"
                           placeholder="Paste image URL..." />
                    <span asp-validation-for="Poster"
                          class="form-field-error"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Rating" class="form-label"></label>
                    <input asp-for="Rating" class="form-input" />
                    <span asp-validation-for="Rating" class="form-field-error"></span>
                </div>

            </div>

            <div class="form-footer">
                <a asp-action="@backAction" class="btn-ghost">Cancel</a>

                <button type="submit" class="btn-submit">
                    Save Changes
                </button>
            </div>

        </form>

    </div>
</div>