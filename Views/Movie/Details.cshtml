@model Netflix_clone.Models.Movie
@{
    ViewData["Title"] = Model.Name;

    var rawUrl    = Model.VideoUrl ?? string.Empty;
    bool isYouTube = rawUrl.Contains("youtube.com") || rawUrl.Contains("youtu.be");
    bool isVimeo   = rawUrl.Contains("vimeo.com");
    bool isDirect  = !isYouTube && !isVimeo;

    string embedUrl = rawUrl;
    if (isYouTube)
    {
        var ytId = string.Empty;
        if (rawUrl.Contains("watch?v="))      ytId = rawUrl.Split("watch?v=").Last().Split('&').First();
        else if (rawUrl.Contains("youtu.be/")) ytId = rawUrl.Split("youtu.be/").Last().Split('?').First();
        else if (rawUrl.Contains("embed/"))    ytId = rawUrl.Split("embed/").Last().Split('?').First();
        if (!string.IsNullOrWhiteSpace(ytId))
            embedUrl = $"https://www.youtube.com/embed/{ytId}?enablejsapi=1&origin={Context.Request.Scheme}://{Context.Request.Host}";
    }
    else if (isVimeo)
    {
        if (!rawUrl.Contains("player.vimeo.com"))
        {
            var vid = rawUrl.TrimEnd('/').Split('/').Last();
            embedUrl = $"https://player.vimeo.com/video/{vid}?api=1";
        }
        else if (!rawUrl.Contains("api=1"))
            embedUrl = rawUrl + (rawUrl.Contains('?') ? "&api=1" : "?api=1");
    }

    bool isLoggedIn = User.Identity?.IsAuthenticated == true;
}

@await Html.PartialAsync("_DetailStyles")

<div class="detail-page">

    <section class="detail-hero">
        <div class="detail-hero__bg" id="heroBg"
             style="background-image:url('@Model.Poster')"></div>
        <div class="detail-hero__overlay"></div>

        <div class="detail-hero__content">
            <div class="detail-type-badge">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <rect x="2" y="2" width="20" height="20" rx="2"/>
                    <path d="M7 2v20M17 2v20M2 12h20M2 7h5M2 17h5M17 7h5M17 17h5"/>
                </svg>
                Movie
            </div>

            <h1 class="detail-title">@Model.Name</h1>

            <div class="detail-meta">
                @if (Model.Rating > 0)
                {
                    <span class="detail-meta__star">★ @Model.Rating.ToString("0.0")</span>
                    <span class="detail-meta__dot"></span>
                }
                @if (Model.DurationSeconds.TotalMinutes > 0)
                {
                    <span>@((int)Model.DurationSeconds.TotalMinutes) min</span>
                    <span class="detail-meta__dot"></span>
                }
                @if (Model.Categories?.Any() == true)
                {
                    <span>@string.Join(" · ", Model.Categories.Select(c => c.Name))</span>
                }
            </div>

            <p class="detail-desc">@Model.Description</p>

            <div class="detail-actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="detail-btn detail-btn--edit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Edit
                </a>

                @if (isLoggedIn)
                {
                    <button id="listBtn" class="detail-btn detail-btn--list"
                            data-media-id="@Model.Id"
                            data-media-type="Movie"
                            data-media-name="@Model.Name"
                            data-media-poster="@Model.Poster">
                        <svg id="listIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        <span id="listLabel">Add to My List</span>
                    </button>
                }
            </div>
        </div>
    </section>

    <div class="detail-body">

        @if (!string.IsNullOrWhiteSpace(rawUrl))
        {
            <div class="player-wrap" id="playerWrap">
                <div class="resume-banner" id="resumeBanner">
                    <span id="resumeText">Resume from last position?</span>
                    <button class="resume-banner__btn" id="resumeBtn">Resume</button>
                    <button class="resume-banner__dismiss" id="dismissBtn" aria-label="Dismiss">✕</button>
                </div>

                @if (isDirect)
                {
                    <video id="myPlayer" controls preload="metadata">
                        <source src="@rawUrl" />
                    </video>
                }
                else
                {
                    <iframe id="myPlayer" src="@embedUrl" title="@Model.Name"
                            allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                }
            </div>
        }

        @if (Model.Categories?.Any() == true)
        {
            <div class="detail-section">
                <div class="detail-section__title">Genres</div>
                <div class="genre-row">
                    @foreach (var cat in Model.Categories)
                    {
                        <span class="genre-pill">@cat.Name</span>
                    }
                </div>
            </div>
        }

        @if (Model.Actors?.Any() == true)
        {
            <div class="detail-section">
                <div class="detail-section__title">Cast</div>
                <div class="cast-scroll">
                    @foreach (var actor in Model.Actors)
                    {
                        <a asp-controller="Actor" asp-action="GetActorByID" asp-route-id="@actor.Id"
                           class="cast-card">
                            @if (!string.IsNullOrWhiteSpace(actor.Photo))
                            {
                                <img class="cast-card__photo" src="@actor.Photo" alt="@actor.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="cast-card__initials" style="display:none">
                                    @(actor.Name?.Substring(0,1).ToUpper())
                                </div>
                            }
                            else
                            {
                                <div class="cast-card__initials">@(actor.Name?.Substring(0,1).ToUpper())</div>
                            }
                            <div class="cast-card__name">@actor.Name</div>
                            @if (!string.IsNullOrWhiteSpace(actor.Bio))
                            {
                                <div class="cast-card__bio">@actor.Bio</div>
                            }
                        </a>
                    }
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
(function () {
    const bg = document.getElementById('heroBg');
    if (bg) {
        const img = new Image();
        img.onload = () => bg.classList.add('loaded');
        img.src = '@Model.Poster';
    }

    const CONTENT_ID = @Model.Id;
    const IS_YOUTUBE = @(isYouTube ? "true" : "false") === 'true';
    const IS_VIMEO   = @(isVimeo   ? "true" : "false") === 'true';
    const IS_DIRECT  = @(isDirect  ? "true" : "false") === 'true';
    const SAVE_EVERY = 15 * 1000;

    let savedSeconds    = 0;
    let ytPlayer        = null;
    let saveTimer       = null;
    let lastKnownSecond = 0;

    function fmt(s) {
        s = Math.floor(s);
        return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');
    }
    function beaconSave(s) {
        s = Math.floor(s);
        if (s <= 0 || !navigator.sendBeacon) return;
        navigator.sendBeacon('/api/history/update',
            new Blob([JSON.stringify({ contentId: CONTENT_ID, watchedSeconds: s })],
                     { type: 'application/json' }));
    }
    async function saveProgress(s) {
        s = Math.floor(s);
        if (s <= 0) return;
        lastKnownSecond = s;
        try {
            const r = await fetch('/api/history/update', {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({ contentId: CONTENT_ID, watchedSeconds: s })
            });
            if (!r.ok) console.warn('[History] save failed', r.status);
        } catch (e) { console.warn('[History] save error', e); }
    }
    async function loadProgress() {
        try {
            const r = await fetch('/api/history/progress/' + CONTENT_ID);
            if (!r.ok) return 0;
            const d = await r.json();
            return (!d.isFinished && d.watchedSeconds > 5) ? d.watchedSeconds : 0;
        } catch { return 0; }
    }
    function showResume(s) {
        if (s <= 0) return;
        savedSeconds = s;
        document.getElementById('resumeText').textContent = 'Resume from ' + fmt(s) + '?';
        document.getElementById('resumeBanner').classList.add('visible');
    }

    const dismissBtn = document.getElementById('dismissBtn');
    if (dismissBtn) dismissBtn.addEventListener('click', () =>
        document.getElementById('resumeBanner').classList.remove('visible'));

    window.addEventListener('beforeunload', () => beaconSave(lastKnownSecond));

    if (IS_DIRECT) {
        const video = document.getElementById('myPlayer');
        if (video) {
            let lastSavedAt = 0;
            video.addEventListener('timeupdate', () => {
                const now = Math.floor(video.currentTime);
                lastKnownSecond = now;
                if (now - lastSavedAt >= 15) { lastSavedAt = now; saveProgress(now); }
            });
            video.addEventListener('pause', () => saveProgress(video.currentTime));
            video.addEventListener('ended', () => saveProgress(video.currentTime));
            video.addEventListener('loadedmetadata', async () => {
                const s = await loadProgress();
                if (s > 0) {
                    showResume(s);
                    document.getElementById('resumeBtn').addEventListener('click', () => {
                        video.currentTime = savedSeconds;
                        document.getElementById('resumeBanner').classList.remove('visible');
                        video.play();
                    });
                }
            });
        }
    } else if (IS_YOUTUBE) {
        window.onYouTubeIframeAPIReady = function () {
            ytPlayer = new YT.Player('myPlayer', {
                events: {
                    onReady: async function () {
                        const s = await loadProgress();
                        if (s > 0) {
                            showResume(s);
                            document.getElementById('resumeBtn').addEventListener('click', () => {
                                ytPlayer.seekTo(savedSeconds, true);
                                document.getElementById('resumeBanner').classList.remove('visible');
                            });
                        }
                    },
                    onStateChange: function (e) {
                        if (e.data === YT.PlayerState.PLAYING) {
                            clearInterval(saveTimer);
                            saveTimer = setInterval(() => {
                                const t = ytPlayer.getCurrentTime();
                                lastKnownSecond = Math.floor(t);
                                saveProgress(t);
                            }, SAVE_EVERY);
                        }
                        if (e.data === YT.PlayerState.PAUSED || e.data === YT.PlayerState.ENDED) {
                            clearInterval(saveTimer);
                            const t = ytPlayer.getCurrentTime();
                            lastKnownSecond = Math.floor(t);
                            saveProgress(t);
                        }
                    }
                }
            });
        };
        var tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        document.getElementsByTagName('script')[0].parentNode.insertBefore(tag, document.getElementsByTagName('script')[0]);
    } else if (IS_VIMEO) {
        var vs = document.createElement('script');
        vs.src = 'https://player.vimeo.com/api/player.js';
        vs.onload = async function () {
            var player = new Vimeo.Player(document.getElementById('myPlayer'));
            const s = await loadProgress();
            if (s > 0) {
                showResume(s);
                document.getElementById('resumeBtn').addEventListener('click', async () => {
                    await player.setCurrentTime(savedSeconds);
                    document.getElementById('resumeBanner').classList.remove('visible');
                    player.play();
                });
            }
            let lastSavedAt = 0;
            player.on('timeupdate', d => {
                const now = Math.floor(d.seconds);
                lastKnownSecond = now;
                if (now - lastSavedAt >= 15) { lastSavedAt = now; saveProgress(now); }
            });
            player.on('pause',  async () => saveProgress(await player.getCurrentTime()));
            player.on('ended',  async () => saveProgress(await player.getCurrentTime()));
        };
        document.head.appendChild(vs);
    }

    @if (isLoggedIn)
    {
        <text>
    const listBtn = document.getElementById('listBtn');
    if (listBtn) {
        fetch('/MyList/Status?mediaId=@Model.Id&mediaType=Movie')
            .then(r => r.json())
            .then(d => setListState(d.inList));

        listBtn.addEventListener('click', function () {
            const fd = new FormData();
            fd.append('mediaId',     listBtn.dataset.mediaId);
            fd.append('mediaType',   listBtn.dataset.mediaType);
            fd.append('mediaName',   listBtn.dataset.mediaName);
            fd.append('mediaPoster', listBtn.dataset.mediaPoster || '');
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
            fetch('/MyList/Toggle', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(d => setListState(d.inList));
        });

        function setListState(inList) {
            const icon  = document.getElementById('listIcon');
            const label = document.getElementById('listLabel');
            if (inList) {
                listBtn.classList.add('in-list');
                icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
                label.textContent = 'In My List';
            } else {
                listBtn.classList.remove('in-list');
                icon.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>';
                label.textContent = 'Add to My List';
            }
        }
    }
        </text>
    }
})();
</script>
@Html.AntiForgeryToken()
}
