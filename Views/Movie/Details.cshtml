@model Netflix_clone.Models.Movie

@{
    ViewData["Title"] = Model.Name;
}

<style>

    .details-page {
        padding: 40px;
    }

    .movie-hero {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        min-height: 520px;
        display: flex;
        align-items: end;
        padding: 40px;
        background-size: cover;
        background-position: center;
    }

    .movie-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0,0,0,0.95), rgba(0,0,0,0.5), rgba(0,0,0,0.2) );
    }

    .movie-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
    }

    .movie-title {
        font-size: 64px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .movie-meta {
        display: flex;
        gap: 18px;
        margin-bottom: 20px;
        color: #d1d5db;
        font-size: 14px;
    }

    .movie-description {
        font-size: 16px;
        line-height: 1.9;
        color: #e5e7eb;
        margin-bottom: 28px;
        max-width: 650px;
    }

    .movie-actions {
        display: flex;
        gap: 14px;
    }

    .movie-btn {
        padding: 12px 24px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        transition: 0.2s;
    }

    .watch-btn {
        background: white;
        color: black;
    }

        .watch-btn:hover {
            transform: translateY(-2px);
        }

    .edit-btn {
        background: #e50914;
        color: white;
    }

        .edit-btn:hover {
            background: #ff1f2d;
        }

    .movie-trailer {
        width: 100%;
        margin-top: 40px;
        display: flex;
        justify-content: center;
    }

        .movie-trailer iframe {
            width: 90%;
            height: 800px;
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.45);
        }

    }

</style>

<div class="details-page">

    <div class="movie-hero"
         style="background-image:url('@Model.Poster')">

        <div class="movie-overlay"></div>

        <div class="movie-content">

            <div class="movie-title">
                @Model.Name
            </div>

            <div class="movie-meta">

                <span>
                    ⭐ @Model.Rating
                </span>

                <span>
                    ⏱ @Model.DurationSeconds
                </span>

            </div>

            <div class="movie-description">
                @Model.Description
            </div>

            <div class="movie-actions">

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="movie-btn edit-btn">
                    Edit Movie
                </a>

            </div>

        </div>

    </div>
    <div class="movie-trailer">

        <iframe src="@Model.VideoUrl"
                title="Movie Trailer"
                allowfullscreen>
        </iframe>

    </div>

</div>