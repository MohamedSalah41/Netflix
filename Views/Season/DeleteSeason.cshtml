@model Netflix_clone.Models.Season

@{
    ViewData["Title"] = "Delete Season";
    ViewBag.ActivePage = "Seasons";
}

<style>
    .confirm-page {
        max-width   : 560px;
        margin      : 40px auto;
        padding     : 0 24px 64px;
    }
    .confirm-back {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        font-size       : 13px;
        color           : var(--text-muted);
        text-decoration : none;
        margin-bottom   : 28px;
        transition      : color 180ms;
    }
    .confirm-back:hover { color: var(--text-secondary); }
    .confirm-card {
        background      : var(--bg-surface);
        border          : 1px solid rgba(248,113,113,0.3);
        border-radius   : var(--radius-lg);
        overflow        : hidden;
    }
    .confirm-card__header {
        padding         : 28px 32px 24px;
        border-bottom   : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        gap             : 16px;
    }
    .confirm-card__icon {
        width           : 48px;
        height          : 48px;
        border-radius   : 12px;
        background      : rgba(248,113,113,0.1);
        border          : 1px solid rgba(248,113,113,0.3);
        display         : flex;
        align-items     : center;
        justify-content : center;
        font-size       : 22px;
        flex-shrink     : 0;
    }
    .confirm-card__title {
        font-family     : var(--font-display);
        font-size       : 24px;
        letter-spacing  : 1px;
        color           : #f87171;
        line-height     : 1;
    }
    .confirm-card__sub {
        font-size       : 13px;
        color           : var(--text-muted);
        margin-top      : 5px;
    }
    .confirm-card__body { padding: 32px; }
    .confirm-warning {
        background      : rgba(248,113,113,0.08);
        border          : 1px solid rgba(248,113,113,0.25);
        border-radius   : var(--radius-md);
        padding         : 14px 18px;
        font-size       : 13px;
        color           : #fca5a5;
        margin-bottom   : 24px;
    }
    .detail-row {
        display         : flex;
        gap             : 16px;
        padding         : 12px 0;
        border-bottom   : 1px solid var(--border-subtle);
        font-size       : 14px;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-row__label {
        width           : 120px;
        flex-shrink     : 0;
        font-size       : 12px;
        font-weight     : 600;
        letter-spacing  : 0.06em;
        text-transform  : uppercase;
        color           : var(--text-muted);
        padding-top     : 2px;
    }
    .detail-row__value { color: var(--text-primary); }
    .confirm-footer {
        padding         : 24px 32px;
        border-top      : 1px solid var(--border-subtle);
        display         : flex;
        gap             : 12px;
        justify-content : flex-end;
    }
    .btn-ghost {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        padding         : 10px 20px;
        border-radius   : var(--radius-full);
        font-family     : var(--font-body);
        font-size       : 13px;
        font-weight     : 500;
        color           : var(--text-secondary);
        background      : transparent;
        border          : 1px solid var(--border-medium);
        text-decoration : none;
        transition      : color 180ms, background 180ms;
    }
    .btn-ghost:hover { color: var(--text-primary); background: var(--bg-elevated); }
    .btn-danger {
        display         : inline-flex;
        align-items     : center;
        gap             : 8px;
        padding         : 10px 24px;
        background      : #dc2626;
        color           : #fff;
        font-family     : var(--font-body);
        font-size       : 13px;
        font-weight     : 600;
        border-radius   : var(--radius-full);
        border          : none;
        cursor          : pointer;
        transition      : background 200ms, box-shadow 200ms, transform 150ms;
    }
    .btn-danger:hover {
        background      : #b91c1c;
        box-shadow      : 0 4px 14px rgba(220,38,38,0.4);
        transform       : translateY(-1px);
    }
    @@media (max-width: 600px) {
        .confirm-page { padding: 0 12px 48px; margin-top: 24px; }
        .confirm-card__header, .confirm-card__body, .confirm-footer { padding: 20px; }
        .confirm-footer { flex-direction: column-reverse; }
        .btn-ghost, .btn-danger { width: 100%; justify-content: center; }
    }
</style>

<div class="confirm-page">
    <a asp-action="GetAllSeasons" class="confirm-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back to Seasons
    </a>

    <div class="confirm-card">
        <div class="confirm-card__header">
            <div class="confirm-card__icon" aria-hidden="true">🗑️</div>
            <div>
                <div class="confirm-card__title">Delete Season</div>
                <div class="confirm-card__sub">This action cannot be undone.</div>
            </div>
        </div>

        <div class="confirm-card__body">
            <div class="confirm-warning">
                You are about to permanently delete <strong>@Model.Name</strong> and all its associated episodes.
            </div>

            <div class="detail-row">
                <span class="detail-row__label">Name</span>
                <span class="detail-row__value">@Model.Name</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Number</span>
                <span class="detail-row__value">@Model.Number</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Series ID</span>
                <span class="detail-row__value">@(Model.SeriesId.HasValue ? Model.SeriesId.ToString() : "—")</span>
            </div>
        </div>

        <div class="confirm-footer">
            <a asp-action="GetAllSeasons" class="btn-ghost">Cancel</a>
            <form asp-action="DeleteSeason" asp-route-id="@Model.Id" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                    </svg>
                    Delete Season
                </button>
            </form>
        </div>
    </div>
</div>
