@* ╔══════════════════════════════════════════════════════════════════════╗
   ║  AddActor.cshtml  —  Create / Add form                               ║
   ║                                                                      ║
   ║  HOW TO REUSE:                                                       ║
   ║  1. CUSTOMISE-MODEL  → change model type                             ║
   ║  2. CUSTOMISE-HEADING → change title, icon, subtitle                 ║
   ║  3. CUSTOMISE-FIELDS  → add/remove form-field <div> blocks           ║
   ║  4. CUSTOMISE-ACTIONS → change asp-action and back link              ║
   ╚══════════════════════════════════════════════════════════════════════╝ *@

@* ── CUSTOMISE-MODEL ── *@
@model Netflix_clone.Models.Actor

@{
    @* ── CUSTOMISE-HEADING ── *@
    ViewData["Title"] = "Add Actor";
    ViewBag.ActivePage = "Actors";

    string formTitle    = "Add Actor";
    string formSubtitle = "Fill in the details below to add a new actor to the system.";
    string formIcon     = "🎭";
    string backAction   = "GetAllActors";   @* CUSTOMISE-ACTIONS *@
    string backLabel    = "Back to Actors";
}

<style>
    /* ── Centred form card layout ── */
    .form-page {
        max-width   : 680px;
        margin      : 40px auto;
        padding     : 0 24px 64px;
    }

    /* Breadcrumb / back link */
    .form-back {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        font-size       : 13px;
        color           : var(--text-muted);
        text-decoration : none;
        margin-bottom   : 28px;
        transition      : color 180ms;
    }
    .form-back:hover { color: var(--text-secondary); }

    /* Card wrapping the entire form */
    .form-card {
        background      : var(--bg-surface);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-lg);
        overflow        : hidden;
    }

    /* Card header strip */
    .form-card__header {
        padding         : 28px 32px 24px;
        border-bottom   : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        gap             : 16px;
    }
    .form-card__icon {
        width           : 48px;
        height          : 48px;
        border-radius   : 12px;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.25);
        display         : flex;
        align-items     : center;
        justify-content : center;
        font-size       : 22px;
        flex-shrink     : 0;
    }
    .form-card__title {
        font-family     : var(--font-display);
        font-size       : 26px;
        letter-spacing  : 1px;
        color           : var(--text-primary);
        line-height     : 1;
    }
    .form-card__sub {
        font-size       : 13px;
        color           : var(--text-muted);
        margin-top      : 5px;
    }

    /* Card body — the form lives here */
    .form-card__body { padding: 32px; }

    /* Validation summary error box */
    .form-error-box {
        background      : rgba(248,113,113,0.08);
        border          : 1px solid rgba(248,113,113,0.3);
        border-radius   : var(--radius-md);
        padding         : 12px 16px;
        margin-bottom   : 24px;
        font-size       : 13px;
        color           : #fca5a5;
    }
    .form-error-box ul { padding-left: 16px; margin: 0; }

    /* Form field group */
    .form-field {
        margin-bottom   : 24px;
    }
    .form-field:last-of-type { margin-bottom: 0; }

    /* Label */
    .form-label {
        display         : block;
        font-size       : 12px;
        font-weight     : 600;
        letter-spacing  : 0.06em;
        text-transform  : uppercase;
        color           : var(--text-secondary);
        margin-bottom   : 8px;
    }

    /* Input / Textarea */
    .form-input,
    .form-textarea {
        width           : 100%;
        padding         : 11px 16px;
        background      : var(--bg-elevated);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-md);
        color           : var(--text-primary);
        font-family     : var(--font-body);
        font-size       : 14px;
        outline         : none;
        transition      : border-color 200ms, box-shadow 200ms;
    }
    .form-input::placeholder,
    .form-textarea::placeholder { color: var(--text-muted); }

    .form-input:focus,
    .form-textarea:focus {
        border-color    : var(--brand);
        box-shadow      : 0 0 0 3px var(--brand-dim);
    }

    /* Inline validation error message */
    .form-field-error {
        display         : block;
        font-size       : 12px;
        color           : #f87171;
        margin-top      : 6px;
    }

    /* Photo URL preview */
    .photo-preview {
        margin-top      : 12px;
        width           : 72px;
        height          : 72px;
        border-radius   : var(--radius-md);
        object-fit      : cover;
        border          : 1px solid var(--border-medium);
        display         : none;   /* shown by JS when URL is valid */
    }

    /* Form footer — submit button row */
    .form-footer {
        padding         : 24px 32px;
        border-top      : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        justify-content : flex-end;
        gap             : 12px;
    }

    /* Cancel (ghost) button */
    .btn-ghost {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        padding         : 10px 20px;
        border-radius   : var(--radius-full);
        font-family     : var(--font-body);
        font-size       : 13px;
        font-weight     : 500;
        color           : var(--text-secondary);
        background      : transparent;
        border          : 1px solid var(--border-medium);
        text-decoration : none;
        transition      : color 180ms, background 180ms, border-color 180ms;
    }
    .btn-ghost:hover {
        color           : var(--text-primary);
        background      : var(--bg-elevated);
        border-color    : var(--border-medium);
    }

    /* Primary submit button */
    .btn-submit {
        display         : inline-flex;
        align-items     : center;
        gap             : 8px;
        padding         : 10px 24px;
        background      : var(--brand);
        color           : #fff;
        font-family     : var(--font-body);
        font-size       : 13px;
        font-weight     : 600;
        border-radius   : var(--radius-full);
        border          : none;
        cursor          : pointer;
        transition      : background 200ms, box-shadow 200ms, transform 150ms;
    }
    .btn-submit:hover {
        background      : var(--brand-hover);
        box-shadow      : var(--shadow-brand);
        transform       : translateY(-1px);
    }
    .btn-submit:active { transform: translateY(0); }

    @@media (max-width: 600px) {
        .form-page { padding: 0 12px 48px; margin-top: 24px; }
        .form-card__header, .form-card__body, .form-footer { padding: 20px; }
        .form-footer { flex-direction: column-reverse; }
        .btn-ghost, .btn-submit { width: 100%; justify-content: center; }
    }
</style>

<div class="form-page">

    @* ── Back link ── *@
    @* ── CUSTOMISE-ACTIONS: change asp-action ── *@
    <a asp-action="@backAction" class="form-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        @backLabel
    </a>

    <div class="form-card">

        @* ── Card Header ── *@
        <div class="form-card__header">
            <div class="form-card__icon" aria-hidden="true">@formIcon</div>
            <div>
                <div class="form-card__title">@formTitle</div>
                <div class="form-card__sub">@formSubtitle</div>
            </div>
        </div>

        @* ── Form Body ── *@
        @* ── CUSTOMISE-ACTIONS: change asp-action ── *@
        <form asp-action="AddActor" id="mainForm" novalidate>
            <div asp-validation-summary="ModelOnly" class="form-error-box text-danger"></div>

            <div class="form-card__body">

                @* ── CUSTOMISE-FIELDS: copy/modify/remove these field blocks ── *@

                @* Field: Name *@
                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" placeholder="e.g. Leonardo DiCaprio" />
                    <span asp-validation-for="Name" class="form-field-error"></span>
                </div>

                @* Field: Bio *@
                <div class="form-field">
                    <label asp-for="Bio" class="form-label"></label>
                    <input asp-for="Bio" class="form-input"
                           placeholder="Short biography or description…" />
                    <span asp-validation-for="Bio" class="form-field-error"></span>
                </div>

                @* Field: Photo URL (with live preview) *@
                <div class="form-field">
                    <label asp-for="Photo" class="form-label"></label>
                    <input asp-for="Photo" class="form-input" id="photoInput"
                           placeholder="https://example.com/actor.jpg" />
                    <span asp-validation-for="Photo" class="form-field-error"></span>
                    @* Live image preview — shown when URL loads successfully *@
                    <img id="photoPreview" class="photo-preview" alt="Photo preview" />
                </div>

            </div><!-- /.form-card__body -->

            @* ── Form Footer: Cancel + Submit ── *@
            <div class="form-footer">
                <a asp-action="@backAction" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Save Actor
                </button>
            </div>
        </form>

    </div><!-- /.form-card -->
</div>

@section Scripts {
    @* Client-side validation (keeps your ValidationScriptsPartial working) *@
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
    // Live photo URL preview
    // When the user pastes a URL into the Photo field, we attempt to load it.
    // If it loads, a small preview thumbnail appears beneath the input.
    (function () {
        const input   = document.getElementById('photoInput');
        const preview = document.getElementById('photoPreview');
        if (!input || !preview) return;

        let timer;

        input.addEventListener('input', function () {
            clearTimeout(timer);
            // Debounce — wait 500ms after the user stops typing before trying to load
            timer = setTimeout(function () {
                const url = input.value.trim();
                if (!url) { preview.style.display = 'none'; return; }

                preview.src   = url;
                preview.style.display = 'none';    // hide while loading

                preview.onload  = function () { preview.style.display = 'block'; };
                preview.onerror = function () { preview.style.display = 'none';  };
            }, 500);
        });
    })();
    </script>
}
