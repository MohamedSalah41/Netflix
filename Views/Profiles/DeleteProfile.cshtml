@model Netflix_clone.Models.Profile
@{
    ViewData["Title"] = "Delete Profile";
    ViewBag.ActivePage = "Profiles";
}

<style>
    .confirm-page { max-width: 480px; margin: 80px auto; padding: 0 24px; text-align: center; }
    .confirm-icon {
        width: 72px; height: 72px; border-radius: 50%;
        background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.25);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 24px; color: #f87171;
    }
    .confirm-title {
        font-family: var(--font-display); font-size: 32px; letter-spacing: 1px;
        color: var(--text-primary); margin-bottom: 12px;
    }
    .confirm-desc { font-size: 15px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 8px; }
    .confirm-name {
        font-size: 18px; font-weight: 700; color: var(--text-primary);
        margin: 16px 0 8px;
    }
    .confirm-warning {
        font-size: 13px; color: var(--text-muted); margin-bottom: 36px;
        padding: 12px 16px; background: rgba(248,113,113,0.06);
        border: 1px solid rgba(248,113,113,0.15); border-radius: var(--radius-md);
    }
    .confirm-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-cancel {
        display: inline-flex; align-items: center; gap: 6px; padding: 11px 24px;
        border-radius: var(--radius-full); font-family: var(--font-body); font-size: 14px;
        font-weight: 500; color: var(--text-secondary); background: transparent;
        border: 1px solid var(--border-medium); text-decoration: none;
        transition: color 180ms, background 180ms;
    }
    .btn-cancel:hover { color: var(--text-primary); background: var(--bg-elevated); }
    .btn-delete {
        display: inline-flex; align-items: center; gap: 8px; padding: 11px 24px;
        background: #dc2626; color: #fff; font-family: var(--font-body);
        font-size: 14px; font-weight: 600; border-radius: var(--radius-full);
        border: none; cursor: pointer; transition: background 200ms, transform 150ms;
    }
    .btn-delete:hover { background: #b91c1c; transform: translateY(-1px); }
</style>

<div class="confirm-page">
    <div class="confirm-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/>
            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
    </div>

    <h1 class="confirm-title">Delete Profile</h1>
    <p class="confirm-desc">You are about to permanently delete this profile.</p>
    <div class="confirm-name">@Model.Name</div>

    <div class="confirm-warning">
        This will also delete all watch history associated with this profile. This action cannot be undone.
    </div>

    <div class="confirm-actions">
        <a asp-action="ManageProfiles" class="btn-cancel">Cancel</a>
        <form asp-action="DeleteProfile" asp-route-id="@Model.Id" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-delete">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                </svg>
                Delete Profile
            </button>
        </form>
    </div>
</div>
