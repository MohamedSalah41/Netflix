@model Netflix_clone.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewBag.ActivePage = "Home";
}

<style>
    .home-page { overflow-x: hidden; }

    /* ── HERO ─────────────────────────────────────────────────────── */
    .hero {
        position       : relative;
        width          : 100%;
        min-height     : 92vh;
        display        : flex;
        align-items    : flex-end;
        overflow       : hidden;
    }
    .hero__bg {
        position       : absolute;
        inset          : 0;
        background-size: cover;
        background-position: center top;
        background-repeat: no-repeat;
        transform      : scale(1.04);
        transition     : transform 8s ease-out;
    }
    .hero__bg.loaded { transform: scale(1); }
    .hero__overlay {
        position       : absolute;
        inset          : 0;
        background     : linear-gradient(
            to right,
            rgba(8,8,16,0.92) 0%,
            rgba(8,8,16,0.55) 45%,
            rgba(8,8,16,0.10) 100%
        ),
        linear-gradient(
            to top,
            rgba(8,8,16,1.00) 0%,
            rgba(8,8,16,0.30) 40%,
            transparent 70%
        );
    }
    .hero__content {
        position       : relative;
        z-index        : 2;
        padding        : 0 64px 72px;
        max-width      : 620px;
    }
    .hero__badge {
        display        : inline-flex;
        align-items    : center;
        gap            : 6px;
        background     : var(--brand-dim);
        border         : 1px solid rgba(229,9,20,0.35);
        border-radius  : var(--radius-full);
        padding        : 4px 12px;
        font-size      : 11px;
        font-weight    : 700;
        color          : var(--brand);
        letter-spacing : 0.08em;
        text-transform : uppercase;
        margin-bottom  : 20px;
    }
    .hero__title {
        font-family    : var(--font-display);
        font-size      : clamp(42px, 6vw, 72px);
        letter-spacing : 2px;
        line-height    : 1;
        color          : var(--text-primary);
        margin-bottom  : 12px;
        text-shadow    : 0 2px 20px rgba(0,0,0,0.6);
    }
    .hero__meta {
        display        : flex;
        align-items    : center;
        gap            : 12px;
        font-size      : 13px;
        color          : var(--text-secondary);
        margin-bottom  : 16px;
        flex-wrap      : wrap;
    }
    .hero__meta-year {
        font-weight    : 700;
        color          : var(--text-primary);
    }
    .hero__meta-dot {
        width          : 4px;
        height         : 4px;
        border-radius  : 50%;
        background     : var(--text-muted);
        flex-shrink    : 0;
    }
    .hero__genres {
        color          : var(--brand);
        font-weight    : 600;
    }
    .hero__desc {
        font-size      : 15px;
        line-height    : 1.65;
        color          : var(--text-secondary);
        margin-bottom  : 32px;
        display        : -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow       : hidden;
    }
    .hero__actions {
        display        : flex;
        align-items    : center;
        gap            : 12px;
        flex-wrap      : wrap;
    }
    .hero-btn {
        display        : inline-flex;
        align-items    : center;
        gap            : 8px;
        padding        : 13px 28px;
        border-radius  : var(--radius-full);
        font-size      : 14px;
        font-weight    : 700;
        transition     : background 200ms, transform 150ms, box-shadow 200ms;
        white-space    : nowrap;
    }
    .hero-btn:active { transform: scale(0.97); }
    .hero-btn--watch {
        background     : #fff;
        color          : #080810;
    }
    .hero-btn--watch:hover {
        background     : rgba(255,255,255,0.88);
        transform      : translateY(-2px);
        box-shadow     : 0 8px 24px rgba(0,0,0,0.4);
        color          : #080810;
    }
    .hero-btn--list {
        background     : rgba(255,255,255,0.12);
        color          : var(--text-primary);
        border         : 1px solid rgba(255,255,255,0.25);
        backdrop-filter: blur(8px);
    }
    .hero-btn--list:hover {
        background     : rgba(255,255,255,0.20);
        transform      : translateY(-2px);
        color          : var(--text-primary);
    }
    .hero__scroll-hint {
        position       : absolute;
        bottom         : 24px;
        right          : 64px;
        display        : flex;
        align-items    : center;
        gap            : 8px;
        font-size      : 12px;
        color          : var(--text-muted);
        animation      : bounce 2s infinite;
    }

    /* ── SECTION ROWS ─────────────────────────────────────────────── */
    .content-section {
        padding        : 48px 0 16px;
    }
    .section-header {
        display        : flex;
        align-items    : center;
        justify-content: space-between;
        padding        : 0 64px 20px;
    }
    .section-title {
        font-family    : var(--font-display);
        font-size      : 26px;
        letter-spacing : 1px;
        color          : var(--text-primary);
    }
    .section-show-more {
        display        : flex;
        align-items    : center;
        gap            : 6px;
        font-size      : 13px;
        color          : var(--text-muted);
        transition     : color 180ms;
    }
    .section-show-more:hover { color: var(--text-secondary); }

    /* ── HORIZONTAL SCROLL RAIL ───────────────────────────────────── */
    .scroll-rail-wrap {
        position       : relative;
    }
    .scroll-rail {
        display        : flex;
        gap            : 12px;
        padding        : 8px 64px 24px;
        overflow-x     : auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .scroll-rail::-webkit-scrollbar { display: none; }

    /* Arrow nav buttons */
    .rail-arrow {
        position       : absolute;
        top            : 50%;
        transform      : translateY(-50%);
        z-index        : 10;
        width          : 44px;
        height         : 44px;
        border-radius  : 50%;
        background     : rgba(13,13,24,0.85);
        border         : 1px solid var(--border-medium);
        color          : var(--text-primary);
        display        : flex;
        align-items    : center;
        justify-content: center;
        cursor         : pointer;
        transition     : background 180ms, transform 180ms;
        backdrop-filter: blur(8px);
    }
    .rail-arrow:hover {
        background     : var(--bg-elevated);
        transform      : translateY(-50%) scale(1.08);
    }
    .rail-arrow--left  { left : 12px; }
    .rail-arrow--right { right: 12px; }

    /* ── CARD — standard portrait ─────────────────────────────────── */
    .media-card {
        flex-shrink    : 0;
        width          : 180px;
        scroll-snap-align: start;
        cursor         : pointer;
        transition     : transform 250ms var(--ease-spring);
        display        : block;
        text-decoration: none;
        color          : inherit;
    }
    .media-card:hover { transform: scale(1.06) translateY(-4px); }
    .media-card__poster {
        width          : 100%;
        aspect-ratio   : 2/3;
        border-radius  : var(--radius-md);
        object-fit     : cover;
        background     : var(--bg-elevated);
        display        : block;
        border         : 1px solid var(--border-subtle);
    }
    .media-card__poster-placeholder {
        width          : 100%;
        aspect-ratio   : 2/3;
        border-radius  : var(--radius-md);
        background     : linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
        border         : 1px solid var(--border-subtle);
        display        : flex;
        flex-direction : column;
        align-items    : center;
        justify-content: center;
        gap            : 8px;
        color          : var(--text-muted);
        font-size      : 28px;
    }
    .media-card__poster-placeholder span {
        font-size      : 11px;
        font-weight    : 600;
        text-align     : center;
        padding        : 0 8px;
        color          : var(--text-secondary);
        line-height    : 1.3;
    }
    .media-card__info {
        padding        : 10px 4px 0;
    }
    .media-card__name {
        font-size      : 13px;
        font-weight    : 600;
        color          : var(--text-primary);
        white-space    : nowrap;
        overflow       : hidden;
        text-overflow  : ellipsis;
    }
    .media-card__rating {
        display        : flex;
        align-items    : center;
        gap            : 4px;
        font-size      : 11px;
        color          : var(--text-muted);
        margin-top     : 4px;
    }
    .media-card__rating-star { color: #f59e0b; }

    /* ── CARD — wide landscape (for "For You" hero row) ──────────── */
    .media-card--wide {
        width          : 280px;
    }
    .media-card--wide .media-card__poster,
    .media-card--wide .media-card__poster-placeholder {
        aspect-ratio   : 16/9;
    }

    /* ── CONTINUE WATCHING CARD ───────────────────────────────────── */
    .cw-card {
        flex-shrink    : 0;
        width          : 220px;
        scroll-snap-align: start;
        cursor         : pointer;
        transition     : transform 250ms var(--ease-spring);
        display        : block;
        text-decoration: none;
        color          : inherit;
    }
    .cw-card:hover { transform: scale(1.05) translateY(-4px); }
    .cw-card__thumb-wrap {
        position       : relative;
        width          : 100%;
        aspect-ratio   : 16/9;
        border-radius  : var(--radius-md);
        overflow       : hidden;
        border         : 1px solid var(--border-subtle);
    }
    .cw-card__thumb {
        width          : 100%;
        height         : 100%;
        object-fit     : cover;
        background     : var(--bg-elevated);
        display        : block;
    }
    .cw-card__thumb-placeholder {
        width          : 100%;
        height         : 100%;
        background     : linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
        display        : flex;
        align-items    : center;
        justify-content: center;
        font-size      : 32px;
        color          : var(--text-muted);
    }
    .cw-card__play-overlay {
        position       : absolute;
        inset          : 0;
        background     : rgba(0,0,0,0.45);
        display        : flex;
        align-items    : center;
        justify-content: center;
        opacity        : 0;
        transition     : opacity 200ms;
    }
    .cw-card:hover .cw-card__play-overlay { opacity: 1; }
    .cw-card__play-icon {
        width          : 44px;
        height         : 44px;
        border-radius  : 50%;
        background     : rgba(255,255,255,0.9);
        display        : flex;
        align-items    : center;
        justify-content: center;
        color          : #080810;
    }
    .cw-card__progress-bar {
        position       : absolute;
        bottom         : 0;
        left           : 0;
        right          : 0;
        height         : 3px;
        background     : rgba(255,255,255,0.2);
    }
    .cw-card__progress-fill {
        height         : 100%;
        background     : var(--brand);
        border-radius  : 0 2px 2px 0;
        transition     : width 600ms var(--ease-out);
    }
    .cw-card__info {
        padding        : 10px 4px 0;
    }
    .cw-card__name {
        font-size      : 13px;
        font-weight    : 600;
        color          : var(--text-primary);
        white-space    : nowrap;
        overflow       : hidden;
        text-overflow  : ellipsis;
    }
    .cw-card__meta {
        font-size      : 11px;
        color          : var(--text-muted);
        margin-top     : 4px;
    }

    /* ── EMPTY STATE ──────────────────────────────────────────────── */
    .empty-state {
        padding        : 40px 64px;
        color          : var(--text-muted);
        font-size      : 14px;
        display        : flex;
        align-items    : center;
        gap            : 10px;
    }

    /* ── ANIMATIONS ───────────────────────────────────────────────── */
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(6px); }
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .hero__content > * {
        animation: fadeUp 0.7s var(--ease-out) both;
    }
    .hero__content > *:nth-child(1) { animation-delay: 0.05s; }
    .hero__content > *:nth-child(2) { animation-delay: 0.15s; }
    .hero__content > *:nth-child(3) { animation-delay: 0.22s; }
    .hero__content > *:nth-child(4) { animation-delay: 0.30s; }
    .hero__content > *:nth-child(5) { animation-delay: 0.38s; }

    @@media (max-width: 768px) {
        .hero__content { padding: 0 24px 56px; }
        .section-header { padding: 0 24px 16px; }
        .scroll-rail { padding: 8px 24px 20px; }
        .empty-state { padding: 24px; }
    }
</style>

<div class="home-page">

    @* ── HERO ──────────────────────────────────────────────────────── *@
    <section class="hero">
        @if (Model?.HeroItem != null)
        {
            <div class="hero__bg" id="heroBg"
                 style="background-image: url('@(string.IsNullOrWhiteSpace(Model.HeroItem.Poster) ? "" : Model.HeroItem.Poster)')">
            </div>
        }
        else
        {
            <div class="hero__bg" style="background: linear-gradient(135deg, #12121f 0%, #1a1a2e 100%)"></div>
        }
        <div class="hero__overlay"></div>

        <div class="hero__content">
            <div class="hero__badge">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                Featured
            </div>

            <h1 class="hero__title">@(Model?.HeroItem?.Name ?? "Welcome to WatchIt")</h1>

            <div class="hero__meta">
                <span class="hero__meta-year">@Model?.HeroYear</span>
                @if (!string.IsNullOrWhiteSpace(Model?.HeroGenres))
                {
                    <span class="hero__meta-dot"></span>
                    <span class="hero__genres">@Model.HeroGenres</span>
                }
                @if (Model?.HeroItem?.Rating > 0)
                {
                    <span class="hero__meta-dot"></span>
                    <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b" style="display:inline;vertical-align:middle;margin-right:3px">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                        @Model?.HeroItem?.Rating.ToString("0.0")
                    </span>
                }
            </div>

            <p class="hero__desc">@(Model?.HeroDescription ?? "Stream the best movies and series, anytime, anywhere.")</p>

            <div class="hero__actions">
                @if (Model?.HeroItem != null)
                {
                    string heroController = Model.HeroItemType == "Movie" ? "Movie" : "Series";
                    string heroAction     = Model.HeroItemType == "Movie" ? "Details" : "GetSeriesById";
                    <a asp-controller="@heroController" asp-action="@heroAction" asp-route-id="@Model.HeroItem.Id"
                       class="hero-btn hero-btn--watch">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="5 3 19 12 5 21 5 3"/>
                        </svg>
                        Watch
                    </a>
                }
                <a href="#" class="hero-btn hero-btn--list">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add To My List
                </a>
            </div>
        </div>

        <div class="hero__scroll-hint" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
            Scroll
        </div>
    </section>


    @* ── FOR YOU ────────────────────────────────────────────────────── *@
    <section class="content-section">
        <div class="section-header">
            <h2 class="section-title">For You</h2>
            <a href="#" class="section-show-more">
                show more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </a>
        </div>
        <div class="scroll-rail-wrap">
            <button class="rail-arrow rail-arrow--left" onclick="scrollRail(this,-1)" aria-label="Scroll left">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            <div class="scroll-rail" id="rail-foryou">
                @if (Model?.ForYouItems != null && Model.ForYouItems.Any())
                {
                    @foreach (var row in Model.ForYouItems)
                    {
                        string ctrl   = row.ItemType == "Movie" ? "Movie" : "Series";
                        string action = row.ItemType == "Movie" ? "Details" : "GetSeriesById";
                        <a asp-controller="@ctrl" asp-action="@action" asp-route-id="@row.Item.Id"
                           class="media-card media-card--wide">
                            @if (!string.IsNullOrWhiteSpace(row.Item.Poster))
                            {
                                <img class="media-card__poster" src="@row.Item.Poster" alt="@row.Item.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="media-card__poster-placeholder" style="display:none;aspect-ratio:16/9">
                                    🎬<span>@row.Item.Name</span>
                                </div>
                            }
                            else
                            {
                                <div class="media-card__poster-placeholder" style="aspect-ratio:16/9">🎬<span>@row.Item.Name</span></div>
                            }
                            <div class="media-card__info">
                                <div class="media-card__name">@row.Item.Name</div>
                                <div class="media-card__rating">
                                    <span class="media-card__rating-star">★</span>
                                    @row.Item.Rating.ToString("0.0")
                                </div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-state">No recommendations yet — add some content to get started.</div>
                }
            </div>
            <button class="rail-arrow rail-arrow--right" onclick="scrollRail(this,1)" aria-label="Scroll right">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        </div>
    </section>


    @* ── CONTINUE WATCHING ──────────────────────────────────────────── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="content-section">
            <div class="section-header">
                <h2 class="section-title">Continue Watching</h2>
                <a href="#" class="section-show-more">
                    show more
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </a>
            </div>
            <div class="scroll-rail-wrap">
                <button class="rail-arrow rail-arrow--left" onclick="scrollRail(this,-1)" aria-label="Scroll left">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <div class="scroll-rail" id="rail-cw">
                    @if (Model?.ContinueWatching != null && Model.ContinueWatching.Any())
                    {
                        @foreach (var cw in Model.ContinueWatching)
                        {
                            string cwCtrl   = cw.ItemType == "Movie" ? "Movie" : "Series";
                            string cwAction = cw.ItemType == "Movie" ? "Details" : "GetSeriesById";
                            <a asp-controller="@cwCtrl" asp-action="@cwAction" asp-route-id="@cw.Item.Id"
                               class="cw-card">
                                <div class="cw-card__thumb-wrap">
                                    @if (!string.IsNullOrWhiteSpace(cw.Item.Poster))
                                    {
                                        <img class="cw-card__thumb" src="@cw.Item.Poster" alt="@cw.Item.Name"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        <div class="cw-card__thumb-placeholder" style="display:none">🎬</div>
                                    }
                                    else
                                    {
                                        <div class="cw-card__thumb-placeholder">🎬</div>
                                    }
                                    <div class="cw-card__play-overlay">
                                        <div class="cw-card__play-icon">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                                <polygon points="5 3 19 12 5 21 5 3"/>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="cw-card__progress-bar">
                                        <div class="cw-card__progress-fill" style="width:@cw.ProgressPercent.ToString("0")%"></div>
                                    </div>
                                </div>
                                <div class="cw-card__info">
                                    <div class="cw-card__name">@cw.Item.Name</div>
                                    <div class="cw-card__meta">@cw.LastWatched</div>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            Nothing in progress yet — start watching something!
                        </div>
                    }
                </div>
                <button class="rail-arrow rail-arrow--right" onclick="scrollRail(this,1)" aria-label="Scroll right">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>
            </div>
        </section>
    }


    @* ── TRENDING NOW ────────────────────────────────────────────────── *@
    <section class="content-section">
        <div class="section-header">
            <h2 class="section-title">Trending Now</h2>
            <a href="#" class="section-show-more">
                show more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </a>
        </div>
        <div class="scroll-rail-wrap">
            <button class="rail-arrow rail-arrow--left" onclick="scrollRail(this,-1)" aria-label="Scroll left">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            <div class="scroll-rail" id="rail-trending">
                @if (Model?.TrendingNow != null && Model.TrendingNow.Any())
                {
                    @foreach (var row in Model.TrendingNow)
                    {
                        string ctrl   = row.ItemType == "Movie" ? "Movie" : "Series";
                        string action = row.ItemType == "Movie" ? "Details" : "GetSeriesById";
                        <a asp-controller="@ctrl" asp-action="@action" asp-route-id="@row.Item.Id"
                           class="media-card">
                            @if (!string.IsNullOrWhiteSpace(row.Item.Poster))
                            {
                                <img class="media-card__poster" src="@row.Item.Poster" alt="@row.Item.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="media-card__poster-placeholder" style="display:none">🎬<span>@row.Item.Name</span></div>
                            }
                            else
                            {
                                <div class="media-card__poster-placeholder">🎬<span>@row.Item.Name</span></div>
                            }
                            <div class="media-card__info">
                                <div class="media-card__name">@row.Item.Name</div>
                                <div class="media-card__rating">
                                    <span class="media-card__rating-star">★</span>
                                    @row.Item.Rating.ToString("0.0")
                                </div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-state">No trending content available.</div>
                }
            </div>
            <button class="rail-arrow rail-arrow--right" onclick="scrollRail(this,1)" aria-label="Scroll right">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        </div>
    </section>

    @* ── NEW RELEASES ────────────────────────────────────────────────── *@
    <section class="content-section" style="padding-bottom:64px">
        <div class="section-header">
            <h2 class="section-title">New Releases</h2>
            <a href="#" class="section-show-more">
                show more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </a>
        </div>
        <div class="scroll-rail-wrap">
            <button class="rail-arrow rail-arrow--left" onclick="scrollRail(this,-1)" aria-label="Scroll left">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            <div class="scroll-rail" id="rail-new">
                @if (Model?.NewReleases != null && Model.NewReleases.Any())
                {
                    @foreach (var row in Model.NewReleases)
                    {
                        string ctrl   = row.ItemType == "Movie" ? "Movie" : "Series";
                        string action = row.ItemType == "Movie" ? "Details" : "GetSeriesById";
                        <a asp-controller="@ctrl" asp-action="@action" asp-route-id="@row.Item.Id"
                           class="media-card">
                            @if (!string.IsNullOrWhiteSpace(row.Item.Poster))
                            {
                                <img class="media-card__poster" src="@row.Item.Poster" alt="@row.Item.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="media-card__poster-placeholder" style="display:none">🎬<span>@row.Item.Name</span></div>
                            }
                            else
                            {
                                <div class="media-card__poster-placeholder">🎬<span>@row.Item.Name</span></div>
                            }
                            <div class="media-card__info">
                                <div class="media-card__name">@row.Item.Name</div>
                                <div class="media-card__rating">
                                    <span class="media-card__rating-star">★</span>
                                    @row.Item.Rating.ToString("0.0")
                                </div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-state">No new releases available.</div>
                }
            </div>
            <button class="rail-arrow rail-arrow--right" onclick="scrollRail(this,1)" aria-label="Scroll right">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        </div>
    </section>

</div>


@section Scripts {
<script>
(function () {
    const bg = document.getElementById('heroBg');
    if (bg) {
        const url = bg.style.backgroundImage;
        if (url && url !== 'url("")') {
            const img = new Image();
            img.onload = function () { bg.classList.add('loaded'); };
            img.src = url.replace(/url\(["']?/, '').replace(/["']?\)$/, '');
        } else {
            bg.classList.add('loaded');
        }
    }
})();

function scrollRail(btn, dir) {
    const wrap = btn.closest('.scroll-rail-wrap');
    const rail = wrap.querySelector('.scroll-rail');
    if (!rail) return;
    const cardWidth = rail.querySelector('.media-card, .cw-card')?.offsetWidth ?? 220;
    rail.scrollBy({ left: dir * (cardWidth + 12) * 3, behavior: 'smooth' });
}
</script>
}
