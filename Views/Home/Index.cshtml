@model Netflix_clone.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewBag.ActivePage = "Home";
}

<style>
    .home-page { overflow-x: hidden; }

    /* ── HERO ─────────────────────────────────────────────────────── */
    .hero {
        position       : relative;
        width          : 100%;
        min-height     : 92vh;
        display        : flex;
        align-items    : flex-end;
        overflow       : hidden;
        margin-top     : -68px;
        padding-top    : 68px;
    }
    .hero__bg {
        position       : absolute;
        inset          : 0;
        background-size: cover;
        background-position: center top;
        background-repeat: no-repeat;
        transform      : scale(1.04);
        transition     : transform 8s ease-out;
    }
    .hero__bg.loaded { transform: scale(1); }
    .hero__overlay {
        position       : absolute;
        inset          : 0;
        background     : linear-gradient(
            to right,
            rgba(8,8,16,0.92) 0%,
            rgba(8,8,16,0.55) 45%,
            rgba(8,8,16,0.10) 100%
        ),
        linear-gradient(
            to top,
            rgba(8,8,16,1.00) 0%,
            rgba(8,8,16,0.30) 40%,
            transparent 70%
        );
    }
    .hero__content {
        position       : relative;
        z-index        : 2;
        padding        : 0 64px 72px;
        max-width      : 620px;
    }
    .hero__badge {
        display        : inline-flex;
        align-items    : center;
        gap            : 6px;
        background     : var(--brand-dim);
        border         : 1px solid rgba(229,9,20,0.35);
        border-radius  : var(--radius-full);
        padding        : 6px 16px;
        font-size      : 13px;
        font-weight    : 700;
        color          : var(--brand);
        letter-spacing : 0.08em;
        text-transform : uppercase;
        margin-bottom  : 20px;
    }
    .hero__title {
        font-family    : var(--font-display);
        font-size      : clamp(56px, 8vw, 96px);
        letter-spacing : 2px;
        line-height    : 1;
        color          : var(--text-primary);
        margin-bottom  : 12px;
        text-shadow    : 0 2px 20px rgba(0,0,0,0.6);
    }
    .hero__meta {
        display        : flex;
        align-items    : center;
        gap            : 12px;
        font-size      : 16px;
        color          : var(--text-secondary);
        margin-bottom  : 16px;
        flex-wrap      : wrap;
    }
    .hero__meta-year {
        font-weight    : 700;
        color          : var(--text-primary);
    }
    .hero__meta-dot {
        width          : 4px;
        height         : 4px;
        border-radius  : 50%;
        background     : var(--text-muted);
        flex-shrink    : 0;
    }
    .hero__genres {
        color          : var(--brand);
        font-weight    : 600;
    }
    .hero__desc {
        font-size      : 18px;
        line-height    : 1.65;
        color          : var(--text-secondary);
        margin-bottom  : 32px;
        display        : -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow       : hidden;
    }
    .hero__actions {
        display        : flex;
        align-items    : center;
        gap            : 12px;
        flex-wrap      : wrap;
    }
    .hero-btn {
        display        : inline-flex;
        align-items    : center;
        gap            : 8px;
        padding        : 16px 36px;
        border-radius  : var(--radius-full);
        font-size      : 17px;
        font-weight    : 700;
        transition     : background 200ms, transform 150ms, box-shadow 200ms;
        white-space    : nowrap;
    }
    .hero-btn:active { transform: scale(0.97); }
    .hero-btn--watch {
        background     : #fff;
        color          : #080810;
    }
    .hero-btn--watch:hover {
        background     : rgba(255,255,255,0.88);
        transform      : translateY(-2px);
        box-shadow     : 0 8px 24px rgba(0,0,0,0.4);
        color          : #080810;
    }
    .hero-btn--list {
        background     : rgba(255,255,255,0.12);
        color          : var(--text-primary);
        border         : 1px solid rgba(255,255,255,0.25);
        backdrop-filter: blur(8px);
    }
    .hero-btn--list:hover {
        background     : rgba(255,255,255,0.20);
        transform      : translateY(-2px);
        color          : var(--text-primary);
    }
    .hero__scroll-hint {
        position       : absolute;
        bottom         : 24px;
        right          : 64px;
        display        : flex;
        align-items    : center;
        gap            : 8px;
        font-size      : 12px;
        color          : var(--text-muted);
        animation      : bounce 2s infinite;
    }
    .hero__age-badge {
        display        : inline-flex;
        align-items    : center;
        padding        : 3px 8px;
        border         : 1px solid rgba(255,255,255,0.4);
        border-radius  : 3px;
        font-size      : 11px;
        font-weight    : 700;
        color          : var(--text-secondary);
        letter-spacing : 0.05em;
    }

    /* ── CARD HOVER POPUP ─────────────────────────────────────────── */
    .card-wrap {
        flex-shrink    : 0;
        position       : relative;
        scroll-snap-align: start;
    }
    .card-wrap:hover { z-index: 50; }
    .card-popup {
        position       : absolute;
        top            : 0;
        left           : 50%;
        transform      : translateX(-50%) scale(0.92);
        width          : 260px;
        background     : #1a1a1a;
        border-radius  : var(--radius-md);
        box-shadow     : 0 20px 60px rgba(0,0,0,0.8);
        border         : 1px solid var(--border-medium);
        opacity        : 0;
        pointer-events : none;
        transition     : opacity 0.25s ease, transform 0.25s ease;
        z-index        : 100;
        overflow       : hidden;
    }
    .card-wrap:hover .card-popup {
        opacity        : 1;
        pointer-events : all;
        transform      : translateX(-50%) scale(1) translateY(-8px);
    }
    .card-popup__thumb {
        width          : 100%;
        aspect-ratio   : 16/9;
        object-fit     : cover;
        display        : block;
        background     : var(--bg-elevated);
    }
    .card-popup__thumb-placeholder {
        width          : 100%;
        aspect-ratio   : 16/9;
        background     : linear-gradient(135deg, #1a1a2e 0%, #262626 100%);
        display        : flex;
        align-items    : center;
        justify-content: center;
        font-size      : 36px;
        color          : var(--text-muted);
    }
    .card-popup__body {
        padding        : 12px 14px 14px;
    }
    .card-popup__actions {
        display        : flex;
        align-items    : center;
        gap            : 8px;
        margin-bottom  : 10px;
    }
    .popup-btn {
        width          : 32px;
        height         : 32px;
        border-radius  : 50%;
        display        : flex;
        align-items    : center;
        justify-content: center;
        transition     : background 180ms, border-color 180ms;
        flex-shrink    : 0;
    }
    .popup-btn--play {
        background     : #fff;
        color          : #0a0a0a;
    }
    .popup-btn--play:hover { background: rgba(255,255,255,0.85); }
    .popup-btn--outline {
        background     : transparent;
        border         : 2px solid rgba(255,255,255,0.5);
        color          : #fff;
    }
    .popup-btn--outline:hover { border-color: #fff; }
    .popup-btn--ml {
        margin-left    : auto;
    }
    .card-popup__match {
        font-size      : 12px;
        font-weight    : 700;
        color          : #46d369;
        margin-bottom  : 6px;
    }
    .card-popup__meta {
        display        : flex;
        align-items    : center;
        gap            : 8px;
        font-size      : 11px;
        color          : var(--text-secondary);
        margin-bottom  : 8px;
        flex-wrap      : wrap;
    }
    .card-popup__age {
        border         : 1px solid rgba(255,255,255,0.4);
        padding        : 1px 5px;
        border-radius  : 2px;
        font-size      : 10px;
        font-weight    : 700;
        color          : var(--text-secondary);
    }
    .card-popup__desc {
        font-size      : 11px;
        line-height    : 1.5;
        color          : var(--text-secondary);
        display        : -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow       : hidden;
        margin-bottom  : 8px;
    }
    .card-popup__genres {
        display        : flex;
        flex-wrap      : wrap;
        gap            : 4px;
    }
    .card-popup__genre-tag {
        font-size      : 10px;
        color          : var(--text-muted);
        background     : rgba(255,255,255,0.07);
        border-radius  : var(--radius-sm);
        padding        : 2px 7px;
    }

    /* ── SECTION ROWS ─────────────────────────────────────────────── */
    .content-section {
        padding        : 48px 0 16px;
    }
    .section-header {
        display        : flex;
        align-items    : center;
        justify-content: space-between;
        padding        : 0 64px 20px;
    }
    .section-title {
        font-family    : var(--font-display);
        font-size      : 26px;
        letter-spacing : 1px;
        color          : var(--text-primary);
    }
    .section-show-more {
        display        : flex;
        align-items    : center;
        gap            : 6px;
        font-size      : 13px;
        color          : var(--text-muted);
        transition     : color 180ms;
    }
    .section-show-more:hover { color: var(--text-secondary); }

    /* ── HORIZONTAL SCROLL RAIL ───────────────────────────────────── */
    .scroll-rail-wrap {
        position       : relative;
    }
    .scroll-rail {
        display        : flex;
        gap            : 12px;
        padding        : 8px 64px 80px;
        overflow-x     : auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .scroll-rail::-webkit-scrollbar { display: none; }

    /* Arrow nav buttons */
    .rail-arrow {
        position       : absolute;
        top            : 50%;
        transform      : translateY(-50%);
        z-index        : 10;
        width          : 44px;
        height         : 44px;
        border-radius  : 50%;
        background     : rgba(13,13,24,0.85);
        border         : 1px solid var(--border-medium);
        color          : var(--text-primary);
        display        : flex;
        align-items    : center;
        justify-content: center;
        cursor         : pointer;
        transition     : background 180ms, transform 180ms;
        backdrop-filter: blur(8px);
    }
    .rail-arrow:hover {
        background     : var(--bg-elevated);
        transform      : translateY(-50%) scale(1.08);
    }
    .rail-arrow--left  { left : 12px; }
    .rail-arrow--right { right: 12px; }

    /* ── CARD — standard portrait ─────────────────────────────────── */
    .media-card {
        width          : 180px;
        cursor         : pointer;
        display        : block;
        text-decoration: none;
        color          : inherit;
    }
    .media-card__poster {
        width          : 100%;
        aspect-ratio   : 2/3;
        border-radius  : var(--radius-md);
        object-fit     : cover;
        background     : var(--bg-elevated);
        display        : block;
        border         : 1px solid var(--border-subtle);
        transition     : border-color 200ms;
    }
    .card-wrap:hover .media-card__poster { border-color: var(--border-medium); }
    .media-card__poster-placeholder {
        width          : 100%;
        aspect-ratio   : 2/3;
        border-radius  : var(--radius-md);
        background     : linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
        border         : 1px solid var(--border-subtle);
        display        : flex;
        flex-direction : column;
        align-items    : center;
        justify-content: center;
        gap            : 8px;
        color          : var(--text-muted);
        font-size      : 28px;
    }
    .media-card__poster-placeholder span {
        font-size      : 11px;
        font-weight    : 600;
        text-align     : center;
        padding        : 0 8px;
        color          : var(--text-secondary);
        line-height    : 1.3;
    }
    .media-card__info {
        padding        : 10px 4px 0;
    }
    .media-card__name {
        font-size      : 13px;
        font-weight    : 600;
        color          : var(--text-primary);
        white-space    : nowrap;
        overflow       : hidden;
        text-overflow  : ellipsis;
    }
    .media-card__rating {
        display        : flex;
        align-items    : center;
        gap            : 4px;
        font-size      : 11px;
        color          : var(--text-muted);
        margin-top     : 4px;
    }
    .media-card__rating-star { color: #f59e0b; }

    /* ── CARD — wide landscape (for "For You" hero row) ──────────── */
    .media-card--wide {
        width          : 280px;
    }
    .media-card--wide .media-card__poster,
    .media-card--wide .media-card__poster-placeholder {
        aspect-ratio   : 16/9;
    }

    /* ── CONTINUE WATCHING CARD ───────────────────────────────────── */
    .cw-card {
        flex-shrink    : 0;
        width          : 220px;
        scroll-snap-align: start;
        cursor         : pointer;
        transition     : transform 250ms var(--ease-spring);
        display        : block;
        text-decoration: none;
        color          : inherit;
    }
    .cw-card:hover { transform: scale(1.05) translateY(-4px); }
    .cw-card__thumb-wrap {
        position       : relative;
        width          : 100%;
        aspect-ratio   : 16/9;
        border-radius  : var(--radius-md);
        overflow       : hidden;
        border         : 1px solid var(--border-subtle);
    }
    .cw-card__thumb {
        width          : 100%;
        height         : 100%;
        object-fit     : cover;
        background     : var(--bg-elevated);
        display        : block;
    }
    .cw-card__thumb-placeholder {
        width          : 100%;
        height         : 100%;
        background     : linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
        display        : flex;
        align-items    : center;
        justify-content: center;
        font-size      : 32px;
        color          : var(--text-muted);
    }
    .cw-card__play-overlay {
        position       : absolute;
        inset          : 0;
        background     : rgba(0,0,0,0.45);
        display        : flex;
        align-items    : center;
        justify-content: center;
        opacity        : 0;
        transition     : opacity 200ms;
    }
    .cw-card:hover .cw-card__play-overlay { opacity: 1; }
    .cw-card__play-icon {
        width          : 44px;
        height         : 44px;
        border-radius  : 50%;
        background     : rgba(255,255,255,0.9);
        display        : flex;
        align-items    : center;
        justify-content: center;
        color          : #080810;
    }
    .cw-card__progress-bar {
        position       : absolute;
        bottom         : 0;
        left           : 0;
        right          : 0;
        height         : 3px;
        background     : rgba(255,255,255,0.2);
    }
    .cw-card__progress-fill {
        height         : 100%;
        background     : var(--brand);
        border-radius  : 0 2px 2px 0;
        transition     : width 600ms var(--ease-out);
    }
    .cw-card__info {
        padding        : 10px 4px 0;
    }
    .cw-card__name {
        font-size      : 13px;
        font-weight    : 600;
        color          : var(--text-primary);
        white-space    : nowrap;
        overflow       : hidden;
        text-overflow  : ellipsis;
    }
    .cw-card__meta {
        font-size      : 11px;
        color          : var(--text-muted);
        margin-top     : 4px;
    }

    /* ── EMPTY STATE ──────────────────────────────────────────────── */
    .empty-state {
        padding        : 40px 64px;
        color          : var(--text-muted);
        font-size      : 14px;
        display        : flex;
        align-items    : center;
        gap            : 10px;
    }

    /* ── TOP 10 ROW ───────────────────────────────────────────────── */
    .top10-item {
        flex-shrink    : 0;
        display        : flex;
        align-items    : flex-end;
        cursor         : pointer;
        scroll-snap-align: start;
        transition     : transform 250ms var(--ease-spring);
    }
    .top10-item:hover { transform: scale(1.04) translateY(-4px); }
    .top10-rank {
        font-family    : var(--font-display);
        font-size      : clamp(80px, 12vw, 140px);
        line-height    : 1;
        font-weight    : 900;
        -webkit-text-stroke: 3px var(--text-muted);
        -webkit-text-fill-color: transparent;
        color          : var(--text-muted);
        user-select    : none;
        flex-shrink    : 0;
    }
    .top10-poster-wrap {
        position       : relative;
        width          : 100px;
        aspect-ratio   : 2/3;
        border-radius  : var(--radius-md);
        overflow       : hidden;
        margin-left    : -28px;
        border         : 1px solid var(--border-subtle);
        flex-shrink    : 0;
    }
    .top10-poster-wrap img {
        width          : 100%;
        height         : 100%;
        object-fit     : cover;
        display        : block;
    }
    .top10-poster-placeholder {
        width          : 100%;
        height         : 100%;
        background     : linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
        display        : flex;
        align-items    : center;
        justify-content: center;
        font-size      : 24px;
        color          : var(--text-muted);
    }

    /* ── HOME FOOTER ──────────────────────────────────────────────── */
    .home-footer {
        background     : #0a0a0a;
        border-top     : 1px solid rgba(255,255,255,0.06);
        padding        : 56px 64px 32px;
        margin-top     : 48px;
    }
    .home-footer__social {
        display        : flex;
        gap            : 16px;
        margin-bottom  : 40px;
    }
    .home-footer__social-btn {
        width          : 40px;
        height         : 40px;
        border-radius  : 50%;
        background     : rgba(255,255,255,0.07);
        border         : 1px solid rgba(255,255,255,0.1);
        display        : flex;
        align-items    : center;
        justify-content: center;
        color          : #a3a3a3;
        font-size      : 16px;
        transition     : background 200ms, color 200ms, border-color 200ms;
        text-decoration: none;
    }
    .home-footer__social-btn:hover {
        background     : rgba(229,9,20,0.15);
        border-color   : rgba(229,9,20,0.4);
        color          : #e50914;
    }
    .home-footer__grid {
        display        : grid;
        grid-template-columns: repeat(4, 1fr);
        gap            : 32px;
        margin-bottom  : 40px;
    }
    .home-footer__col-title {
        font-size      : 11px;
        font-weight    : 700;
        letter-spacing : 0.1em;
        text-transform : uppercase;
        color          : #a3a3a3;
        margin-bottom  : 16px;
    }
    .home-footer__links {
        display        : flex;
        flex-direction : column;
        gap            : 12px;
    }
    .home-footer__link {
        font-size      : 13px;
        color          : #a3a3a3;
        text-decoration: none;
        transition     : color 180ms;
    }
    .home-footer__link:hover { color: #fff; }
    .home-footer__bottom {
        border-top     : 1px solid rgba(255,255,255,0.06);
        padding-top    : 24px;
        display        : flex;
        align-items    : center;
        justify-content: space-between;
        flex-wrap      : wrap;
        gap            : 12px;
    }
    .home-footer__service-code {
        display        : inline-flex;
        align-items    : center;
        padding        : 6px 14px;
        border         : 1px solid rgba(255,255,255,0.2);
        border-radius  : 3px;
        font-size      : 12px;
        color          : #a3a3a3;
        text-decoration: none;
        transition     : border-color 180ms, color 180ms;
    }
    .home-footer__service-code:hover { border-color: #fff; color: #fff; }
    .home-footer__copy {
        font-size      : 12px;
        color          : #5a5a5a;
    }

    /* ── ANIMATIONS ───────────────────────────────────────────────── */
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(6px); }
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .hero__content > * {
        animation: fadeUp 0.7s var(--ease-out) both;
    }
    .hero__content > *:nth-child(1) { animation-delay: 0.05s; }
    .hero__content > *:nth-child(2) { animation-delay: 0.15s; }
    .hero__content > *:nth-child(3) { animation-delay: 0.22s; }
    .hero__content > *:nth-child(4) { animation-delay: 0.30s; }
    .hero__content > *:nth-child(5) { animation-delay: 0.38s; }

    @@media (max-width: 768px) {
        .hero__content { padding: 0 24px 56px; }
        .section-header { padding: 0 24px 16px; }
        .scroll-rail { padding: 8px 24px 60px; }
        .empty-state { padding: 24px; }
        .home-footer { padding: 40px 24px 24px; }
        .home-footer__grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
        .card-popup { display: none; }
    }
    @@media (max-width: 480px) {
        .home-footer__grid { grid-template-columns: 1fr; }
    }
</style>

<div class="home-page">

    @* ── HERO ──────────────────────────────────────────────────────── *@
    <section class="hero">
        @if (Model?.HeroItem != null)
        {
            <div class="hero__bg" id="heroBg"
                 style="background-image: url('@(string.IsNullOrWhiteSpace(Model.HeroItem.Poster) ? "" : Model.HeroItem.Poster)')">
            </div>
        }
        else
        {
            <div class="hero__bg" style="background: linear-gradient(135deg, #12121f 0%, #1a1a2e 100%)"></div>
        }
        <div class="hero__overlay"></div>

        <div class="hero__content">
            <div class="hero__badge">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                Featured
            </div>

            <h1 class="hero__title">@(Model?.HeroItem?.Name ?? "Welcome to WatchIt")</h1>

            <div class="hero__meta">
                <span class="hero__meta-year">@Model?.HeroYear</span>
                @if (!string.IsNullOrWhiteSpace(Model?.HeroGenres))
                {
                    <span class="hero__meta-dot"></span>
                    <span class="hero__genres">@Model.HeroGenres</span>
                }
                @if (Model?.HeroItem?.Rating > 0)
                {
                    <span class="hero__meta-dot"></span>
                    <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b" style="display:inline;vertical-align:middle;margin-right:3px">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                        @Model?.HeroItem?.Rating.ToString("0.0")
                    </span>
                }
            </div>

            <p class="hero__desc">@(Model?.HeroDescription ?? "Stream the best movies and series, anytime, anywhere.")</p>

            <div class="hero__actions">
