@section Scripts {
<script>
(function () {
    const bg = document.getElementById('heroBg');
    if (bg) {
        const url = bg.style.backgroundImage;
        if (url && url !== 'url("")') {
            const img = new Image();
            img.onload = function () { bg.classList.add('loaded'); };
            img.src = url.replace(/url\(["']?/, '').replace(/["']?\)$/, '');
        } else {
            bg.classList.add('loaded');
        }
    }
})();

function scrollRail(btn, dir) {
    const wrap = btn.closest('.scroll-rail-wrap');
    const rail = wrap.querySelector('.scroll-rail');
    if (!rail) return;
    const cardWidth = rail.querySelector('.card-wrap, .media-card, .cw-card, .top10-item')?.offsetWidth ?? 200;
    rail.scrollBy({ left: dir * (cardWidth + 12) * 3, behavior: 'smooth' });
}
</script>
}
