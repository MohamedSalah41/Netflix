<style>
    /* ── Centred form card layout ── */
    .form-page {
        max-width: 680px;
        margin: 40px auto;
        padding: 0 24px 64px;
    }

    /* Breadcrumb / back link */
    .form-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 28px;
        transition: color 180ms;
    }

        .form-back:hover {
            color: var(--text-secondary);
        }

    /* Card wrapping the entire form */
    .form-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-medium);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    /* Card header strip */
    .form-card__header {
        padding: 28px 32px 24px;
        border-bottom: 1px solid var(--border-subtle);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .form-card__icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--brand-dim);
        border: 1px solid rgba(229,9,20,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .form-card__title {
        font-family: var(--font-display);
        font-size: 26px;
        letter-spacing: 1px;
        color: var(--text-primary);
        line-height: 1;
    }

    .form-card__sub {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* Card body — the form lives here */
    .form-card__body {
        padding: 32px;
    }

    /* Validation summary error box */
    .form-error-box {
        background: rgba(248,113,113,0.08);
        border: 1px solid rgba(248,113,113,0.3);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        margin-bottom: 24px;
        font-size: 13px;
        color: #fca5a5;
    }

        .form-error-box ul {
            padding-left: 16px;
            margin: 0;
        }

    /* Form field group */
    .form-field {
        margin-bottom: 24px;
    }

        .form-field:last-of-type {
            margin-bottom: 0;
        }

    /* Label */
    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }

    /* Input / Textarea */
    .form-input,
    .form-textarea {
        width: 100%;
        padding: 11px 16px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-medium);
        border-radius: var(--radius-md);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 14px;
        outline: none;
        transition: border-color 200ms, box-shadow 200ms;
    }

        .form-input::placeholder,
        .form-textarea::placeholder {
            color: var(--text-muted);
        }

        .form-input:focus,
        .form-textarea:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px var(--brand-dim);
        }

    /* Inline validation error message */
    .form-field-error {
        display: block;
        font-size: 12px;
        color: #f87171;
        margin-top: 6px;
    }

    /* Photo URL preview */
    .photo-preview {
        margin-top: 12px;
        width: 72px;
        height: 72px;
        border-radius: var(--radius-md);
        object-fit: cover;
        border: 1px solid var(--border-medium);
        display: none; /* shown by JS when URL is valid */
    }

    /* Form footer — submit button row */
    .form-footer {
        padding: 24px 32px;
        border-top: 1px solid var(--border-subtle);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
    }

    /* Cancel (ghost) button */
    .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        border-radius: var(--radius-full);
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
        background: transparent;
        border: 1px solid var(--border-medium);
        text-decoration: none;
        transition: color 180ms, background 180ms, border-color 180ms;
    }

        .btn-ghost:hover {
            color: var(--text-primary);
            background: var(--bg-elevated);
            border-color: var(--border-medium);
        }

    /* Primary submit button */
    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        background: var(--brand);
        color: #fff;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 600;
        border-radius: var(--radius-full);
        border: none;
        cursor: pointer;
        transition: background 200ms, box-shadow 200ms, transform 150ms;
    }

        .btn-submit:hover {
            background: var(--brand-hover);
            box-shadow: var(--shadow-brand);
            transform: translateY(-1px);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

    @@media (max-width: 600px) {
        .form-page {
            padding: 0 12px 48px;
            margin-top: 24px;
        }

        .form-card__header, .form-card__body, .form-footer {
            padding: 20px;
        }

        .form-footer {
            flex-direction: column-reverse;
        }

        .btn-ghost, .btn-submit {
            width: 100%;
            justify-content: center;
        }
    }
</style>