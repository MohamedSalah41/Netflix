<style>
    .detail-page { padding: 0 0 80px; }

    .detail-hero {
        position           : relative;
        min-height         : 88vh;
        display            : flex;
        align-items        : flex-end;
        overflow           : hidden;
        background-size    : cover;
        background-position: center top;
        margin-top         : -68px;
        padding-top        : 68px;
    }
    .detail-hero__bg {
        position           : absolute;
        inset              : 0;
        background-size    : cover;
        background-position: center;
        transform          : scale(1.04);
        transition         : transform 8s ease-out;
    }
    .detail-hero__bg.loaded { transform: scale(1); }
    .detail-hero__overlay {
        position  : absolute;
        inset     : 0;
        background: linear-gradient(
            to right,
            rgba(8,8,16,0.96) 0%,
            rgba(8,8,16,0.55) 50%,
            rgba(8,8,16,0.10) 100%
        ),
        linear-gradient(
            to top,
            rgba(8,8,16,1.00) 0%,
            rgba(8,8,16,0.20) 50%,
            transparent 80%
        );
    }
    .detail-hero__content {
        position  : relative;
        z-index   : 2;
        padding   : 0 64px 64px;
        max-width : 700px;
    }
    .detail-type-badge {
        display        : inline-flex;
        align-items    : center;
        gap            : 6px;
        background     : var(--brand-dim);
        border         : 1px solid rgba(229,9,20,0.35);
        border-radius  : var(--radius-full);
        padding        : 4px 14px;
        font-size      : 11px;
        font-weight    : 700;
        color          : var(--brand);
        letter-spacing : 0.08em;
        text-transform : uppercase;
        margin-bottom  : 18px;
    }
    .detail-title {
        font-family   : var(--font-display);
        font-size     : clamp(40px, 6vw, 76px);
        letter-spacing: 2px;
        line-height   : 1;
        color         : var(--text-primary);
        margin-bottom : 16px;
        text-shadow   : 0 2px 24px rgba(0,0,0,0.7);
    }
    .detail-meta {
        display      : flex;
        align-items  : center;
        gap          : 10px;
        flex-wrap    : wrap;
        font-size    : 13px;
        color        : var(--text-secondary);
        margin-bottom: 14px;
    }
    .detail-meta__dot {
        width        : 4px;
        height       : 4px;
        border-radius: 50%;
        background   : var(--text-muted);
        flex-shrink  : 0;
    }
    .detail-meta__star { color: #f59e0b; font-weight: 700; }
    .detail-desc {
        font-size    : 15px;
        line-height  : 1.75;
        color        : var(--text-secondary);
        margin-bottom: 28px;
        max-width    : 580px;
    }
    .detail-actions {
        display  : flex;
        gap      : 12px;
        flex-wrap: wrap;
    }
    .detail-btn {
        display        : inline-flex;
        align-items    : center;
        gap            : 8px;
        padding        : 12px 26px;
        border-radius  : var(--radius-full);
        font-size      : 14px;
        font-weight    : 700;
        transition     : background 200ms, transform 150ms, box-shadow 200ms;
        white-space    : nowrap;
        text-decoration: none;
    }
    .detail-btn:active { transform: scale(0.97); }
    .detail-btn--edit {
        background: var(--brand);
        color     : #fff;
    }
    .detail-btn--edit:hover {
        background: var(--brand-hover);
        box-shadow: var(--shadow-brand);
        transform : translateY(-2px);
        color     : #fff;
    }
    .detail-btn--list {
        background  : rgba(255,255,255,0.10);
        color       : var(--text-primary);
        border      : 1px solid rgba(255,255,255,0.22);
        backdrop-filter: blur(8px);
    }
    .detail-btn--list:hover {
        background: rgba(255,255,255,0.18);
        transform : translateY(-2px);
        color     : var(--text-primary);
    }
    .detail-btn--list.in-list {
        background  : var(--brand-dim);
        border-color: rgba(229,9,20,0.4);
        color       : var(--brand);
    }

    .detail-body {
        padding  : 0 64px;
        max-width: 1400px;
    }

    .detail-section { margin-top: 56px; }
    .detail-section__title {
        font-family   : var(--font-display);
        font-size     : 26px;
        letter-spacing: 1px;
        color         : var(--text-primary);
        margin-bottom : 24px;
        display       : flex;
        align-items   : center;
        gap           : 10px;
    }
    .detail-section__title::after {
        content   : '';
        flex      : 1;
        height    : 1px;
        background: var(--border-subtle);
        margin-left: 12px;
    }

    .genre-row {
        display  : flex;
        flex-wrap: wrap;
        gap      : 10px;
    }
    .genre-pill {
        padding      : 6px 16px;
        border-radius: var(--radius-full);
        background   : var(--bg-elevated);
        border       : 1px solid var(--border-medium);
        font-size    : 13px;
        font-weight  : 500;
        color        : var(--text-secondary);
        transition   : background 180ms, color 180ms, border-color 180ms;
    }
    .genre-pill:hover {
        background  : var(--brand-dim);
        border-color: rgba(229,9,20,0.3);
        color       : var(--brand);
    }

    .seasons-grid {
        display              : grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap                  : 16px;
    }
    .season-card {
        background     : var(--bg-surface);
        border         : 1px solid var(--border-subtle);
        border-radius  : var(--radius-lg);
        overflow       : hidden;
        text-decoration: none;
        display        : block;
        transition     : transform 220ms var(--ease-spring), border-color 180ms, box-shadow 180ms;
    }
    .season-card:hover {
        transform   : translateY(-6px);
        border-color: var(--border-medium);
        box-shadow  : var(--shadow-md);
    }
    .season-card__thumb {
        width       : 100%;
        aspect-ratio: 16/9;
        object-fit  : cover;
        background  : var(--bg-elevated);
        display     : block;
    }
    .season-card__placeholder {
        width           : 100%;
        aspect-ratio    : 16/9;
        background      : linear-gradient(135deg, var(--bg-elevated), var(--bg-surface));
        display         : flex;
        align-items     : center;
        justify-content : center;
        font-size       : 32px;
        color           : var(--text-muted);
    }
    .season-card__body { padding: 16px; }
    .season-card__num {
        font-family   : var(--font-display);
        font-size     : 20px;
        letter-spacing: 1px;
        color         : var(--text-primary);
    }
    .season-card__name {
        font-size  : 13px;
        color      : var(--text-muted);
        margin-top : 4px;
    }
    .season-card__eps {
        display     : inline-flex;
        align-items : center;
        gap         : 4px;
        margin-top  : 10px;
        font-size   : 12px;
        font-weight : 600;
        color       : var(--brand);
        background  : var(--brand-dim);
        border      : 1px solid rgba(229,9,20,0.2);
        border-radius: var(--radius-full);
        padding     : 3px 10px;
    }

    .cast-scroll {
        display       : flex;
        gap           : 16px;
        overflow-x    : auto;
        padding-bottom: 8px;
        scrollbar-width: none;
    }
    .cast-scroll::-webkit-scrollbar { display: none; }
    .cast-card {
        flex-shrink    : 0;
        width          : 140px;
        text-decoration: none;
        transition     : transform 220ms var(--ease-spring);
    }
    .cast-card:hover { transform: translateY(-6px); }
    .cast-card__photo {
        width        : 100%;
        aspect-ratio : 1;
        border-radius: var(--radius-lg);
        object-fit   : cover;
        background   : var(--bg-elevated);
        border       : 1px solid var(--border-subtle);
        display      : block;
    }
    .cast-card__initials {
        width           : 100%;
        aspect-ratio    : 1;
        border-radius   : var(--radius-lg);
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.2);
        display         : flex;
        align-items     : center;
        justify-content : center;
        font-family     : var(--font-display);
        font-size       : 32px;
        color           : var(--brand);
    }
    .cast-card__name {
        font-size  : 13px;
        font-weight: 600;
        color      : var(--text-primary);
        margin-top : 10px;
        text-align : center;
        line-height: 1.3;
    }
    .cast-card__bio {
        font-size  : 11px;
        color      : var(--text-muted);
        text-align : center;
        margin-top : 4px;
        overflow   : hidden;
        display    : -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .player-wrap {
        margin-top      : 56px;
        display         : flex;
        justify-content : center;
        position        : relative;
    }
    .player-wrap iframe,
    .player-wrap video {
        width        : 92%;
        height       : 780px;
        border       : none;
        border-radius: var(--radius-lg);
        box-shadow   : 0 24px 60px rgba(0,0,0,0.6);
        background   : #000;
    }

    .resume-banner {
        display        : none;
        position       : absolute;
        top            : 16px;
        left           : 50%;
        transform      : translateX(-50%);
        background     : rgba(13,13,24,0.92);
        border         : 1px solid var(--border-medium);
        border-radius  : var(--radius-full);
        padding        : 10px 20px;
        font-size      : 13px;
        color          : var(--text-primary);
        gap            : 12px;
        align-items    : center;
        z-index        : 10;
        white-space    : nowrap;
        backdrop-filter: blur(8px);
    }
    .resume-banner.visible { display: flex; }
    .resume-banner__btn {
        background   : var(--brand);
        color        : #fff;
        border       : none;
        border-radius: var(--radius-full);
        padding      : 5px 14px;
        font-size    : 12px;
        font-weight  : 600;
        cursor       : pointer;
        transition   : background 180ms;
    }
    .resume-banner__btn:hover { background: var(--brand-hover); }
    .resume-banner__dismiss {
        color     : var(--text-muted);
        cursor    : pointer;
        font-size : 18px;
        background: none;
        border    : none;
        padding   : 0 4px;
        line-height: 1;
    }

    @@media (max-width: 768px) {
        .detail-hero__content { padding: 0 24px 48px; }
        .detail-body          { padding: 0 24px; }
        .seasons-grid         { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
        .player-wrap iframe,
        .player-wrap video    { height: 260px; }
    }
</style>
