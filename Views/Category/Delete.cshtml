@* ╔══════════════════════════════════════════════════════════════════════╗
   ║  Delete.cshtml  —  Delete confirmation page                          ║
   ╚══════════════════════════════════════════════════════════════════════╝ *@

@model Netflix_clone.Models.Category

@{
    ViewData["Title"] = "Delete Category";
    ViewBag.ActivePage = "Categories";

    string formTitle    = "Delete Category";
    string formSubtitle = "This action cannot be undone. Please confirm deletion.";
    string backAction   = "Index";
    string backLabel    = "Back to Categories";
}

<style>
    .form-page {
        max-width   : 560px;
        margin      : 40px auto;
        padding     : 0 24px 64px;
    }
    .form-back {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        font-size       : 13px;
        color           : var(--text-muted);
        text-decoration : none;
        margin-bottom   : 28px;
        transition      : color 180ms;
    }
    .form-back:hover { color: var(--text-secondary); }

    .form-card {
        background      : var(--bg-surface);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-lg);
        overflow        : hidden;
    }
    .form-card__header {
        padding         : 28px 32px 24px;
        border-bottom   : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        gap             : 16px;
    }
    /* Red/warning icon for delete */
    .form-card__icon {
        width           : 48px;
        height          : 48px;
        border-radius   : 12px;
        background      : rgba(248,113,113,0.1);
        border          : 1px solid rgba(248,113,113,0.25);
        display         : flex;
        align-items     : center;
        justify-content : center;
        color           : #f87171;
        flex-shrink     : 0;
    }
    .form-card__title {
        font-family     : var(--font-display);
        font-size       : 30px;
        letter-spacing  : 1px;
        color           : var(--text-primary);
        line-height     : 1;
    }
    .form-card__sub {
        font-size       : 15px;
        color           : var(--text-muted);
        margin-top      : 5px;
    }
    .form-card__body { padding: 32px; }

    /* Warning alert box */
    .delete-warning {
        background      : rgba(248,113,113,0.08);
        border          : 1px solid rgba(248,113,113,0.3);
        border-radius   : var(--radius-md);
        padding         : 16px 20px;
        margin-bottom   : 24px;
        display         : flex;
        align-items     : flex-start;
        gap             : 12px;
    }
    .delete-warning__icon {
        flex-shrink     : 0;
        margin-top      : 2px;
        color           : #f87171;
    }
    .delete-warning__text {
        font-size       : 15px;
        color           : #fca5a5;
        line-height     : 1.5;
    }
    .delete-warning__text strong { color: #f87171; }

    /* Details list */
    .detail-list {
        background      : var(--bg-elevated);
        border          : 1px solid var(--border-subtle);
        border-radius   : var(--radius-md);
        padding         : 20px;
    }
    .detail-row {
        display         : flex;
        padding         : 10px 0;
        border-bottom   : 1px solid var(--border-subtle);
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-label {
        font-size       : 12px;
        font-weight     : 600;
        letter-spacing  : 0.06em;
        text-transform  : uppercase;
        color           : var(--text-muted);
        width           : 80px;
        flex-shrink     : 0;
    }
    .detail-value {
        font-size       : 15px;
        color           : var(--text-primary);
        font-weight     : 500;
    }

    /* Category badge in details */
    .cat-badge {
        display         : inline-flex;
        align-items     : center;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.2);
        border-radius   : var(--radius-full);
        padding         : 4px 14px;
        font-size       : 14px;
        font-weight     : 600;
        color           : var(--brand);
    }

    .form-footer {
        padding         : 24px 32px;
        border-top      : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        justify-content : flex-end;
        gap             : 12px;
    }
    .btn-ghost {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        padding         : 11px 22px;
        border-radius   : var(--radius-full);
        font-family     : var(--font-body);
        font-size       : 14px;
        font-weight     : 500;
        color           : var(--text-secondary);
        background      : transparent;
        border          : 1px solid var(--border-medium);
        text-decoration : none;
        transition      : color 180ms, background 180ms;
    }
    .btn-ghost:hover { color: var(--text-primary); background: var(--bg-elevated); }

    /* Red delete button */
    .btn-delete {
        display         : inline-flex;
        align-items     : center;
        gap             : 8px;
        padding         : 11px 26px;
        background      : #dc2626;
        color           : #fff;
        font-family     : var(--font-body);
        font-size       : 14px;
        font-weight     : 600;
        border-radius   : var(--radius-full);
        border          : none;
        cursor          : pointer;
        transition      : background 200ms, box-shadow 200ms, transform 150ms;
    }
    .btn-delete:hover {
        background      : #ef4444;
        box-shadow      : 0 0 20px rgba(239,68,68,0.4);
        transform       : translateY(-1px);
    }
    .btn-delete:active { transform: translateY(0); }

    @@media (max-width: 600px) {
        .form-page { padding: 0 12px 48px; margin-top: 24px; }
        .form-card__header, .form-card__body, .form-footer { padding: 20px; }
        .form-footer { flex-direction: column-reverse; }
        .btn-ghost, .btn-delete { width: 100%; justify-content: center; }
    }
</style>

<div class="form-page">

    <a asp-action="@backAction" class="form-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        @backLabel
    </a>

    <div class="form-card">

        <div class="form-card__header">
            <div class="form-card__icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.75">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <div>
                <div class="form-card__title">@formTitle</div>
                <div class="form-card__sub">@formSubtitle</div>
            </div>
        </div>

        <div class="form-card__body">

            <div class="delete-warning">
                <div class="delete-warning__icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                </div>
                <div class="delete-warning__text">
                    Are you sure you want to delete <strong>@Model?.Name</strong>?
                    This action cannot be undone. If this category is assigned to any movies or series,
                    the deletion may fail.
                </div>
            </div>

            <div class="detail-list">
                <div class="detail-row">
                    <div class="detail-label">ID</div>
                    <div class="detail-value">@Model?.Id</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Name</div>
                    <div class="detail-value">
                        <span class="cat-badge">@Model?.Name</span>
                    </div>
                </div>
            </div>

        </div>

        <form asp-action="Delete" asp-route-id="@Model?.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="form-footer">
                <a asp-action="@backAction" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-delete">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                    </svg>
                    Yes, Delete Category
                </button>
            </div>
        </form>

    </div>
</div>
