@* ╔══════════════════════════════════════════════════════════════════════╗
   ║  Add.cshtml  —  Create new category form                             ║
   ╚══════════════════════════════════════════════════════════════════════╝ *@

@model Netflix_clone.Models.Category

@{
    ViewData["Title"] = "Add Category";
    ViewBag.ActivePage = "Categories";

    string formTitle    = "Add Category";
    string formSubtitle = "Fill in the details below to create a new content category.";
    string backAction   = "Index";
    string backLabel    = "Back to Categories";
}

<style>
    .form-page {
        max-width   : 560px;
        margin      : 40px auto;
        padding     : 0 24px 64px;
    }
    .form-back {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        font-size       : 13px;
        color           : var(--text-muted);
        text-decoration : none;
        margin-bottom   : 28px;
        transition      : color 180ms;
    }
    .form-back:hover { color: var(--text-secondary); }

    .form-card {
        background      : var(--bg-surface);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-lg);
        overflow        : hidden;
    }
    .form-card__header {
        padding         : 28px 32px 24px;
        border-bottom   : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        gap             : 16px;
    }
    .form-card__icon {
        width           : 48px;
        height          : 48px;
        border-radius   : 12px;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.25);
        display         : flex;
        align-items     : center;
        justify-content : center;
        color           : var(--brand);
        flex-shrink     : 0;
    }
    .form-card__title {
        font-family     : var(--font-display);
        font-size       : 30px;
        letter-spacing  : 1px;
        color           : var(--text-primary);
        line-height     : 1;
    }
    .form-card__sub {
        font-size       : 15px;
        color           : var(--text-muted);
        margin-top      : 5px;
    }
    .form-card__body { padding: 32px; }

    .form-error-box {
        background      : rgba(248,113,113,0.08);
        border          : 1px solid rgba(248,113,113,0.3);
        border-radius   : var(--radius-md);
        padding         : 12px 16px;
        margin-bottom   : 24px;
        font-size       : 14px;
        color           : #fca5a5;
    }
    .form-error-box ul { padding-left: 16px; margin: 0; }

    .form-field { margin-bottom: 24px; }
    .form-field:last-of-type { margin-bottom: 0; }

    .form-label {
        display         : block;
        font-size       : 13px;
        font-weight     : 600;
        letter-spacing  : 0.05em;
        text-transform  : uppercase;
        color           : var(--text-secondary);
        margin-bottom   : 8px;
    }
    .form-hint {
        font-size       : 13px;
        color           : var(--text-muted);
        margin-bottom   : 8px;
        margin-top      : -4px;
    }
    .form-input {
        width           : 100%;
        padding         : 12px 16px;
        background      : var(--bg-elevated);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-md);
        color           : var(--text-primary);
        font-family     : var(--font-body);
        font-size       : 15px;
        outline         : none;
        transition      : border-color 200ms, box-shadow 200ms;
    }
    .form-input::placeholder { color: var(--text-muted); }
    .form-input:focus {
        border-color    : var(--brand);
        box-shadow      : 0 0 0 3px var(--brand-dim);
    }
    .form-field-error {
        display         : block;
        font-size       : 13px;
        color           : #f87171;
        margin-top      : 6px;
    }

    /* Character counter */
    .char-counter {
        font-size       : 12px;
        color           : var(--text-muted);
        text-align      : right;
        margin-top      : 4px;
    }
    .char-counter.warn { color: #f59e0b; }
    .char-counter.over { color: #f87171; }

    .form-footer {
        padding         : 24px 32px;
        border-top      : 1px solid var(--border-subtle);
        display         : flex;
        align-items     : center;
        justify-content : flex-end;
        gap             : 12px;
    }
    .btn-ghost {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        padding         : 11px 22px;
        border-radius   : var(--radius-full);
        font-family     : var(--font-body);
        font-size       : 14px;
        font-weight     : 500;
        color           : var(--text-secondary);
        background      : transparent;
        border          : 1px solid var(--border-medium);
        text-decoration : none;
        transition      : color 180ms, background 180ms, border-color 180ms;
    }
    .btn-ghost:hover { color: var(--text-primary); background: var(--bg-elevated); }
    .btn-submit {
        display         : inline-flex;
        align-items     : center;
        gap             : 8px;
        padding         : 11px 26px;
        background      : var(--brand);
        color           : #fff;
        font-family     : var(--font-body);
        font-size       : 14px;
        font-weight     : 600;
        border-radius   : var(--radius-full);
        border          : none;
        cursor          : pointer;
        transition      : background 200ms, box-shadow 200ms, transform 150ms;
    }
    .btn-submit:hover {
        background      : var(--brand-hover);
        box-shadow      : var(--shadow-brand);
        transform       : translateY(-1px);
    }
    .btn-submit:active { transform: translateY(0); }

    @@media (max-width: 600px) {
        .form-page { padding: 0 12px 48px; margin-top: 24px; }
        .form-card__header, .form-card__body, .form-footer { padding: 20px; }
        .form-footer { flex-direction: column-reverse; }
        .btn-ghost, .btn-submit { width: 100%; justify-content: center; }
    }
</style>

<div class="form-page">

    <a asp-action="@backAction" class="form-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        @backLabel
    </a>

    <div class="form-card">

        <div class="form-card__header">
            <div class="form-card__icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.75">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                    <line x1="7" y1="7" x2="7.01" y2="7"/>
                </svg>
            </div>
            <div>
                <div class="form-card__title">@formTitle</div>
                <div class="form-card__sub">@formSubtitle</div>
            </div>
        </div>

        <form asp-action="Add" id="mainForm" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-error-box text-danger"></div>

            <div class="form-card__body">

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <p class="form-hint">Max 20 characters. Used to tag movies and series.</p>
                    <input asp-for="Name" class="form-input" id="nameInput"
                           placeholder="e.g. Action, Drama, Sci-Fi…"
                           maxlength="20" autocomplete="off" />
                    <div class="char-counter" id="charCounter">0 / 20</div>
                    <span asp-validation-for="Name" class="form-field-error"></span>
                </div>

            </div>

            <div class="form-footer">
                <a asp-action="@backAction" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-submit">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Save Category
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
    // Live character counter for the Name field (max 20)
    (function () {
        const input   = document.getElementById('nameInput');
        const counter = document.getElementById('charCounter');
        if (!input || !counter) return;

        const max = 20;

        function update() {
            const len = input.value.length;
            counter.textContent = len + ' / ' + max;
            counter.className   = 'char-counter';
            if (len >= max)        counter.classList.add('over');
            else if (len >= max * 0.8) counter.classList.add('warn');
        }

        update(); // run on load (handles pre-filled values on validation failure)
        input.addEventListener('input', update);
    })();
    </script>
}
