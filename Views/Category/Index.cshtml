@* ╔══════════════════════════════════════════════════════════════════════╗
   ║  Index.cshtml  —  Category list / index page                         ║
   ╚══════════════════════════════════════════════════════════════════════╝ *@

@model IEnumerable<Netflix_clone.Models.Category>

@{
    ViewData["Title"] = "Categories";
    ViewBag.ActivePage = "Categories";

    string pageTitle    = "Categories";
    string pageSubtitle = "Browse and manage all content categories in the system.";
    string addAction    = "Add";
    string addLabel     = "Add Category";
}

<style>
    /* ── Page Hero ── */
    .pg-hero {
        padding         : 40px 48px 32px;
        display         : flex;
        align-items     : center;
        justify-content : space-between;
        flex-wrap       : wrap;
        gap             : 16px;
        border-bottom   : 1px solid var(--border-subtle);
    }
    .pg-hero__left   { display: flex; align-items: center; gap: 16px; }
    .pg-hero__icon   {
        width           : 52px;
        height          : 52px;
        border-radius   : 14px;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.25);
        display         : flex;
        align-items     : center;
        justify-content : center;
        color           : var(--brand);
        flex-shrink     : 0;
    }
    .pg-hero__title {
        font-family     : var(--font-display);
        font-size       : 36px;
        letter-spacing  : 1px;
        color           : var(--text-primary);
        line-height     : 1;
    }
    .pg-hero__sub {
        font-size       : 15px;
        color           : var(--text-muted);
        margin-top      : 6px;
    }

    /* Add button */
    .btn-add {
        display         : inline-flex;
        align-items     : center;
        gap             : 8px;
        padding         : 10px 20px;
        background      : var(--brand);
        color           : #fff;
        font-family     : var(--font-body);
        font-size       : 13px;
        font-weight     : 600;
        border-radius   : var(--radius-full);
        border          : none;
        text-decoration : none;
        transition      : background 200ms, box-shadow 200ms, transform 150ms;
        cursor          : pointer;
    }
    .btn-add:hover {
        background  : var(--brand-hover);
        box-shadow  : var(--shadow-brand);
        transform   : translateY(-1px);
        color       : #fff;
    }

    /* ── TempData alerts ── */
    .pg-alert {
        margin          : 20px 48px 0;
        padding         : 14px 20px;
        border-radius   : var(--radius-md);
        font-size       : 15px;
        display         : flex;
        align-items     : center;
        gap             : 10px;
    }
    .pg-alert--success {
        background      : rgba(52,211,153,0.1);
        border          : 1px solid rgba(52,211,153,0.3);
        color           : #6ee7b7;
    }
    .pg-alert--error {
        background      : rgba(248,113,113,0.08);
        border          : 1px solid rgba(248,113,113,0.3);
        color           : #fca5a5;
    }

    /* ── Toolbar ── */
    .pg-toolbar {
        padding         : 20px 48px;
        display         : flex;
        align-items     : center;
        gap             : 12px;
        flex-wrap       : wrap;
    }
    .toolbar-search {
        display         : flex;
        align-items     : center;
        gap             : 8px;
        background      : var(--bg-elevated);
        border          : 1px solid var(--border-medium);
        border-radius   : var(--radius-full);
        padding         : 8px 16px;
        flex            : 1;
        max-width       : 360px;
    }
    .toolbar-search svg { color: var(--text-muted); flex-shrink: 0; }
    .toolbar-search input {
        background  : transparent;
        border      : none;
        outline     : none;
        color       : var(--text-primary);
        font-family : var(--font-body);
        font-size   : 15px;
        width       : 100%;
    }
    .toolbar-search input::placeholder { color: var(--text-muted); }
    .toolbar-count {
        font-size   : 14px;
        color       : var(--text-muted);
        margin-left : auto;
    }

    /* ── Table ── */
    .pg-table-wrap {
        padding     : 0 48px 48px;
        overflow-x  : auto;
    }
    .pg-table {
        width           : 100%;
        border-collapse : separate;
        border-spacing  : 0 6px;
    }
    .pg-table thead th {
        padding         : 10px 16px;
        font-size       : 12px;
        font-weight     : 700;
        letter-spacing  : 0.08em;
        text-transform  : uppercase;
        color           : var(--text-muted);
        text-align      : left;
        border-bottom   : 1px solid var(--border-subtle);
        white-space     : nowrap;
    }
    .pg-table tbody tr {
        background  : var(--bg-surface);
        transition  : background 180ms, transform 180ms;
    }
    .pg-table tbody tr:hover {
        background  : var(--bg-elevated);
        transform   : translateX(2px);
    }
    .pg-table tbody td {
        padding         : 16px 16px;
        font-size       : 15px;
        color           : var(--text-secondary);
        vertical-align  : middle;
    }
    .pg-table tbody td:first-child {
        color           : var(--text-primary);
        font-weight     : 500;
        border-radius   : var(--radius-md) 0 0 var(--radius-md);
        padding-left    : 20px;
    }
    .pg-table tbody td:last-child {
        border-radius   : 0 var(--radius-md) var(--radius-md) 0;
        padding-right   : 20px;
    }

    /* Category name pill */
    .cat-badge {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        background      : var(--brand-dim);
        border          : 1px solid rgba(229,9,20,0.2);
        border-radius   : var(--radius-full);
        padding         : 4px 14px;
        font-size       : 14px;
        font-weight     : 600;
        color           : var(--brand);
        letter-spacing  : 0.03em;
    }

    /* Action buttons */
    .row-actions {
        display         : flex;
        align-items     : center;
        gap             : 4px;
        justify-content : flex-end;
    }
    .action-btn {
        display         : inline-flex;
        align-items     : center;
        gap             : 6px;
        padding         : 7px 14px;
        border-radius   : var(--radius-full);
        font-size       : 13px;
        font-weight     : 500;
        text-decoration : none;
        border          : 1px solid transparent;
        transition      : background 180ms, border-color 180ms, color 180ms;
        white-space     : nowrap;
    }
    .action-btn--edit {
        color        : #60a5fa;
        border-color : rgba(96,165,250,0.2);
    }
    .action-btn--edit:hover {
        background   : rgba(96,165,250,0.1);
        border-color : rgba(96,165,250,0.4);
        color        : #93c5fd;
    }
    .action-btn--delete {
        color        : #f87171;
        border-color : rgba(248,113,113,0.2);
    }
    .action-btn--delete:hover {
        background   : rgba(248,113,113,0.1);
        border-color : rgba(248,113,113,0.4);
        color        : #fca5a5;
    }

    /* Empty state */
    .pg-empty {
        padding         : 80px 48px;
        text-align      : center;
        color           : var(--text-muted);
    }
    .pg-empty__icon {
        width           : 64px;
        height          : 64px;
        margin          : 0 auto 20px;
        background      : var(--bg-elevated);
        border          : 1px solid var(--border-medium);
        border-radius   : 18px;
        display         : flex;
        align-items     : center;
        justify-content : center;
        color           : var(--text-muted);
    }
    .pg-empty__text { font-size: 16px; }

    @@media (max-width: 768px) {
        .pg-hero, .pg-toolbar, .pg-table-wrap, .pg-alert { padding-left: 20px; padding-right: 20px; }
        .pg-hero { padding-top: 24px; }
    }
</style>

@* ── TempData Feedback ── *@
@if (TempData["Success"] != null)
{
    <div class="pg-alert pg-alert--success" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="pg-alert pg-alert--error" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        @TempData["Error"]
    </div>
}

@* ── Page Hero ── *@
<div class="pg-hero">
    <div class="pg-hero__left">
        <div class="pg-hero__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.75">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
        </div>
        <div>
            <div class="pg-hero__title">@pageTitle</div>
            <div class="pg-hero__sub">@pageSubtitle</div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
    <a asp-action="@addAction" class="btn-add">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        @addLabel
    </a>
    }
</div>

@* ── Toolbar ── *@
<div class="pg-toolbar">
    <div class="toolbar-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="tableFilter" placeholder="Filter categories…" autocomplete="off" />
    </div>
    <span class="toolbar-count" id="rowCount"></span>
</div>

@* ── Table ── *@
<div class="pg-table-wrap">
    @if (Model != null && Model.Any())
    {
        <table class="pg-table" id="dataTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td style="color:var(--text-muted); width:60px">@cat.Id</td>
                        <td>
                            <span class="cat-badge">@cat.Name</span>
                        </td>
                        <td>
                            <div class="row-actions">
                                @if (User.IsInRole("Admin"))
                                {
                                <a asp-action="Update" asp-route-id="@cat.Id"
                                   class="action-btn action-btn--edit">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                    Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@cat.Id"
                                   class="action-btn action-btn--delete">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                        <path d="M10 11v6M14 11v6"/>
                                    </svg>
                                    Delete
                                </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="pg-empty">
            <div class="pg-empty__icon" aria-hidden="true">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.5">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                    <line x1="7" y1="7" x2="7.01" y2="7"/>
                </svg>
            </div>
            <div class="pg-empty__text">No categories yet. Add one to get started.</div>
        </div>
    }
</div>

@section Scripts {
    <script>
    (function () {
        const input   = document.getElementById('tableFilter');
        const table   = document.getElementById('dataTable');
        const countEl = document.getElementById('rowCount');
        if (!input || !table) return;

        const rows = Array.from(table.querySelectorAll('tbody tr'));

        function updateCount() {
            const visible = rows.filter(r => r.style.display !== 'none').length;
            countEl.textContent = visible + ' of ' + rows.length + ' categories';
        }

        updateCount();

        input.addEventListener('input', function () {
            const q = input.value.trim().toLowerCase();
            rows.forEach(function (row) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
            updateCount();
        });
    })();
    </script>
}
