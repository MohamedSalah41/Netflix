@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<partial name="_MovieFormStyle" />

<div class="form-page">
    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="form-back">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back to Sign In
    </a>

    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon">🎬</div>
            <div>
                <div class="form-card__title">Create Account</div>
                <div class="form-card__sub">Join and start watching today</div>
            </div>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div class="form-card__body">
                <div asp-validation-summary="All" class="form-error-box" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Input.UserName" class="form-label">Username</label>
                    <input asp-for="Input.UserName" class="form-input" autocomplete="username" aria-required="true" placeholder="Choose a username" />
                    <span asp-validation-for="Input.UserName" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-input" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-input" autocomplete="new-password" aria-required="true" placeholder="Create a password" />
                    <span asp-validation-for="Input.Password" class="form-field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="form-input" autocomplete="new-password" aria-required="true" placeholder="Repeat your password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="form-field-error"></span>
                </div>
            </div>

            <div class="form-footer" style="justify-content:space-between;flex-wrap:wrap;gap:12px;">
                <span style="font-size:13px;color:var(--text-muted);">
                    Already have an account?
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" style="color:var(--brand);text-decoration:none;">Sign in</a>
                </span>
                <button id="registerSubmit" type="submit" class="btn-submit">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>
                    Create Account
                </button>
            </div>
        </form>
        @if (Model.ExternalLogins?.Count > 0)
        {
            <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
                <p style="font-size:13px;color:var(--text-muted);text-align:center;margin-bottom:12px;">Or sign up with</p>
                <form asp-area="Identity" asp-page="/Account/ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        @foreach (var provider in Model.ExternalLogins)
                        {
                            <button type="submit" name="provider" value="@provider.Name" class="btn-submit" style="background:transparent;border:1px solid var(--border);color:var(--text);">
                                Sign up with @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
