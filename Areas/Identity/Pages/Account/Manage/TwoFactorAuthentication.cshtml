@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="~/Views/Shared/_MovieFormStyle.cshtml" />

<style>
    .tfa-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: var(--radius-full);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
    }
    .tfa-status-badge.enabled {
        background: rgba(74,222,128,0.12);
        color: #4ade80;
        border: 1px solid rgba(74,222,128,0.25);
    }
    .tfa-status-badge.disabled {
        background: rgba(248,113,113,0.1);
        color: #f87171;
        border: 1px solid rgba(248,113,113,0.25);
    }
    .tfa-info-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0;
        border-bottom: 1px solid var(--border-subtle);
        font-size: 14px;
        color: var(--text-secondary);
    }
    .tfa-info-row:last-child { border-bottom: none; }
    .tfa-info-label { color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }
</style>

<div class="form-page">
    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon">🛡️</div>
            <div>
                <div class="form-card__title">Two-Factor Auth</div>
                <div class="form-card__sub">Add an extra layer of security to your account</div>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="form-card__body">
            @if (Model.Is2faEnabled)
            {
                <div class="tfa-info-row">
                    <span class="tfa-info-label">Status</span>
                    <span class="tfa-status-badge enabled">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Enabled
                    </span>
                </div>
                @if (Model.RecoveryCodesLeft == 0)
                {
                    <div class="form-error-box" style="margin-top:16px;">
                        <strong>You have no recovery codes left.</strong>
                        You must <a asp-page="./GenerateRecoveryCodes" style="color:#fca5a5;">generate a new set of recovery codes</a> before you can log in with a recovery code.
                    </div>
                }
                else if (Model.RecoveryCodesLeft == 1)
                {
                    <div class="form-error-box" style="margin-top:16px;">
                        You have <strong>1 recovery code</strong> left. <a asp-page="./GenerateRecoveryCodes" style="color:#fca5a5;">Generate new recovery codes</a>.
                    </div>
                }
                else if (Model.RecoveryCodesLeft <= 3)
                {
                    <div class="form-error-box" style="background:rgba(251,191,36,0.08);border-color:rgba(251,191,36,0.3);color:#fcd34d;margin-top:16px;">
                        You have <strong>@Model.RecoveryCodesLeft recovery codes</strong> left. <a asp-page="./GenerateRecoveryCodes" style="color:#fcd34d;">Generate new recovery codes</a>.
                    </div>
                }
                <div class="tfa-info-row" style="margin-top:8px;">
                    <span class="tfa-info-label">Recovery Codes</span>
                    <span style="color:var(--text-secondary);">@Model.RecoveryCodesLeft remaining</span>
                </div>
            }
            else
            {
                <div class="tfa-info-row">
                    <span class="tfa-info-label">Status</span>
                    <span class="tfa-status-badge disabled">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                        Disabled
                    </span>
                </div>
                <p style="color:var(--text-muted);font-size:13px;margin-top:16px;line-height:1.6;">
                    Two-factor authentication is not enabled. Enable it to add an extra layer of security to your account.
                </p>
            }
        </div>

        <div class="form-footer" style="flex-wrap:wrap;gap:10px;justify-content:flex-start;">
            @if (Model.HasAuthenticator)
            {
                <a asp-page="./EnableAuthenticator" class="btn-ghost" style="text-decoration:none;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Setup Authenticator
                </a>
                <a asp-page="./ResetAuthenticator" class="btn-ghost" style="text-decoration:none;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
                    Reset Authenticator
                </a>
            }
            else
            {
                <a asp-page="./EnableAuthenticator" class="btn-submit" style="text-decoration:none;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Enable 2FA
                </a>
            }
            @if (Model.Is2faEnabled)
            {
                <a asp-page="./GenerateRecoveryCodes" class="btn-ghost" style="text-decoration:none;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    Recovery Codes
                </a>
                <form method="post" asp-page-handler="Disable2fa" style="margin:0;">
                    <button type="submit" class="btn-ghost" style="color:#f87171;border-color:rgba(248,113,113,0.3);">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                        Disable 2FA
                    </button>
                </form>
            }
        </div>
    </div>
</div>
