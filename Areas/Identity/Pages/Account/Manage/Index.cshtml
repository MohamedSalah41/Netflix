@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="~/Views/Shared/_MovieFormStyle.cshtml" />

<div class="form-page">
    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon">👤</div>
            <div>
                <div class="form-card__title">Profile</div>
                <div class="form-card__sub">Update your account information</div>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />

        <form id="profile-form" method="post">
            <div class="form-card__body">
                <div asp-validation-summary="ModelOnly" class="form-error-box" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-input" placeholder="Your username" disabled />
                </div>

                <div class="form-field">
                    <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="Input.PhoneNumber" class="form-input" placeholder="Enter your phone number" />
                    <span asp-validation-for="Input.PhoneNumber" class="form-field-error"></span>
                </div>
            </div>

            <div class="form-footer">
                <button id="update-profile-button" type="submit" class="btn-submit">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
