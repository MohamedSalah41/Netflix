@page
@model IndexModel
@{
    ViewData["Title"] = "Profile Settings";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="wi-settings-wrapper">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>

        <!-- Content -->
        <div class="col-md-9">
            <div class="wi-settings-card">
                <h3>Profile Settings</h3>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="@(Model.StatusMessage.StartsWith("Error") ? "wi-alert-danger" : "wi-alert-success") mb-4"
                         role="alert">
                        @Model.StatusMessage
                    </div>
                }

                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="wi-alert-danger mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Username"
                               class="form-control wi-form-control"
                               placeholder="Username"
                               disabled />
                        <label asp-for="Username">Username</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.PhoneNumber"
                               class="form-control wi-form-control"
                               placeholder="Phone number" />
                        <label asp-for="Input.PhoneNumber">Phone Number</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="btn btn-wi-primary">
                        Save Changes
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
