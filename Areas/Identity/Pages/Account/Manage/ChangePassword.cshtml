@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="wi-settings-wrapper">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>

        <!-- Content -->
        <div class="col-md-9">
            <div class="wi-settings-card">
                <h3>Change Password</h3>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="@(Model.StatusMessage.StartsWith("Error") ? "wi-alert-danger" : "wi-alert-success") mb-4"
                         role="alert">
                        @Model.StatusMessage
                    </div>
                }

                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="wi-alert-danger mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword"
                               class="form-control wi-form-control"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Current password" />
                        <label asp-for="Input.OldPassword">Current Password</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.NewPassword"
                               class="form-control wi-form-control"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="New password" />
                        <label asp-for="Input.NewPassword">New Password</label>
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword"
                               class="form-control wi-form-control"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="Confirm new password" />
                        <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-wi-primary">
                        Update Password
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
