@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<partial name="~/Views/Shared/_MovieFormStyle.cshtml" />

<div class="form-page">
    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon">✉️</div>
            <div>
                <div class="form-card__title">Email</div>
                <div class="form-card__sub">Manage your account email address</div>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="form-card__body">
            <div class="form-field">
                <label class="form-label">Current Email</label>
                <input value="@Model.Email" class="form-input" disabled />
                @if (Model.IsEmailConfirmed)
                {
                    <span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;color:#4ade80;margin-top:6px;">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Verified
                    </span>
                }
                else
                {
                    <span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;color:#f87171;margin-top:6px;">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Not verified
                    </span>
                }
            </div>
        </div>

        @if (!Model.IsEmailConfirmed)
        {
            <form id="send-verification-form" asp-page-handler="SendVerificationEmail" method="post">
                <div class="form-footer" style="justify-content:flex-start;">
                    <button id="send-verification-btn" type="submit" class="btn-ghost">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.42z"/></svg>
                        Send Verification Email
                    </button>
                </div>
            </form>
        }

        <form id="change-email-form" asp-page-handler="ChangeEmail" method="post">
            <div class="form-card__body" style="padding-top:0;">
                <div asp-validation-summary="ModelOnly" class="form-error-box" role="alert"></div>
                <div class="form-field">
                    <label asp-for="Input.NewEmail" class="form-label">New Email Address</label>
                    <input asp-for="Input.NewEmail" class="form-input" autocomplete="email" aria-required="true" placeholder="Enter new email address" />
                    <span asp-validation-for="Input.NewEmail" class="form-field-error"></span>
                </div>
            </div>
            <div class="form-footer">
                <button id="change-email-button" type="submit" class="btn-submit">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    Change Email
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
