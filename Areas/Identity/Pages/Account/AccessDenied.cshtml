@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center"
     style="min-height: 70vh; padding: 2rem;">

    <div style="font-size: 5rem; line-height: 1; margin-bottom: 1rem;">🔒</div>

    <h1 class="fw-bold" style="font-size: 2.5rem; color: #fff;">Access Denied</h1>
    <p style="color: var(--wi-muted); max-width: 400px; margin: 1rem auto 2rem;">
        You don't have permission to view this page.
        If you think this is a mistake, please contact support.
    </p>

    <a asp-area="" asp-controller="Home" asp-action="Index"
       class="btn btn-wi-primary px-5" style="width: auto; border-radius: 4px;">
        Back to Home
    </a>

</div>
