@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<partial name="_MovieFormStyle" />

<style>
    .access-denied-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        text-align: center;
        padding: 40px 24px;
    }

    .access-denied-icon {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: var(--brand-dim);
        border: 1px solid rgba(229,9,20,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 44px;
        margin-bottom: 28px;
    }

    .access-denied-code {
        font-family: var(--font-display);
        font-size: 72px;
        font-weight: 700;
        color: var(--brand);
        line-height: 1;
        margin-bottom: 12px;
        letter-spacing: 4px;
    }

    .access-denied-title {
        font-family: var(--font-display);
        font-size: 26px;
        color: var(--text-primary);
        margin-bottom: 12px;
        letter-spacing: 1px;
    }

    .access-denied-desc {
        font-size: 14px;
        color: var(--text-muted);
        max-width: 380px;
        line-height: 1.6;
        margin-bottom: 36px;
    }
</style>

<div class="access-denied-page">
    <div class="access-denied-icon">🔒</div>
    <div class="access-denied-code">403</div>
    <div class="access-denied-title">Access Denied</div>
    <p class="access-denied-desc">
        You don't have permission to view this page.
        If you think this is a mistake, please contact support.
    </p>
    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-submit" style="text-decoration:none;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Go Back Home
    </a>
</div>
