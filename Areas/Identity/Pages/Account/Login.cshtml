@page "/Account/Login"
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="wi-auth-wrapper">
    <div class="wi-auth-card">

        <h1>Sign In</h1>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="wi-alert-danger mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control wi-form-control"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="Email" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password"
                       class="form-control wi-form-control"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                </div>
                @* Uncomment when ForgotPassword page is scaffolded:
                <a class="wi-auth-link" asp-page="./ForgotPassword" style="color: var(--wi-muted);">Forgot password?</a>
                *@
            </div>

            <button id="login-submit" type="submit" class="btn btn-wi-primary mb-4">
                Sign In
            </button>

            <p class="wi-auth-link text-center mb-0">
                New to WatchIt?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
            </p>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
