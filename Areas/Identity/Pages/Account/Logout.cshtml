@page "/Account/Logout"
@model LogoutModel
@{
    ViewData["Title"] = "Sign Out";
}

<partial name="_MovieFormStyle" />

<div class="form-page" style="max-width:480px;">
    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__icon">👋</div>
            <div>
                <div class="form-card__title">Sign Out</div>
                <div class="form-card__sub">We hope to see you again soon</div>
            </div>
        </div>

        <div class="form-card__body" style="text-align:center;padding-top:40px;padding-bottom:40px;">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <p style="color:var(--text-secondary);font-size:14px;margin-bottom:28px;">
                    Are you sure you want to sign out?
                </p>
                <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="btn-submit" style="margin:0 auto;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                        Yes, Sign Out
                    </button>
                </form>
            }
            else
            {
                <svg width="64" height="64" fill="none" stroke="var(--brand)" stroke-width="1.5" viewBox="0 0 24 24" style="margin-bottom:16px;opacity:0.7;">
                    <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 0 0 1.946-.806 3.42 3.42 0 0 1 4.438 0 3.42 3.42 0 0 0 1.946.806 3.42 3.42 0 0 1 3.138 3.138 3.42 3.42 0 0 0 .806 1.946 3.42 3.42 0 0 1 0 4.438 3.42 3.42 0 0 0-.806 1.946 3.42 3.42 0 0 1-3.138 3.138 3.42 3.42 0 0 0-1.946.806 3.42 3.42 0 0 1-4.438 0 3.42 3.42 0 0 0-1.946-.806 3.42 3.42 0 0 1-3.138-3.138 3.42 3.42 0 0 0-.806-1.946 3.42 3.42 0 0 1 0-4.438 3.42 3.42 0 0 0 .806-1.946 3.42 3.42 0 0 1 3.138-3.138z"/>
                </svg>
                <p style="color:var(--text-secondary);font-size:15px;margin-bottom:28px;">
                    You have successfully signed out.
                </p>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-submit" style="text-decoration:none;">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Go to Home
                </a>
            }
        </div>
    </div>
</div>
